<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- POS -->
    <Color x:Key="PageBackground">#F1F5F9</Color>
    <Color x:Key="AccentOrange">#EA580C</Color>
    <Color x:Key="AccentGreen">#22C55E</Color>
    <Color x:Key="AccentBlue">#3B82F6</Color>
    <Color x:Key="ErrorRed">#EF4444</Color>
    <Color x:Key="InputBackground">#F3F4F6</Color>
    <Color x:Key="GreenSurface">#EDFDF4</Color>

    <!-- Panel / UI chrome -->
    <Color x:Key="PanelNavy">#1E293B</Color>
    <Color x:Key="SlateActive">#475569</Color>
    <Color x:Key="OrangeDark">#C04800</Color>

    <SolidColorBrush x:Key="AccentGreenBrush"    Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="AccentBlueBrush"     Color="{StaticResource AccentBlue}"/>
    <SolidColorBrush x:Key="ErrorRedBrush"       Color="{StaticResource ErrorRed}"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackground}"/>
    <SolidColorBrush x:Key="GreenSurfaceBrush"   Color="{StaticResource GreenSurface}"/>

    <!-- Escala de grises (usados en textos, bordes, fondos) -->
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>

    <!-- Escala tipográfica responsiva-->
    <x:Double x:Key="UIFontXS">11</x:Double>
    <x:Double x:Key="UIFontSM">12</x:Double>
    <x:Double x:Key="UIFontMD">13</x:Double>
    <x:Double x:Key="UIFontLG">16</x:Double>
    <x:Double x:Key="UIFontXL">18</x:Double>
    <x:Double x:Key="UIFontXXL">30</x:Double>
</ResourceDictionary>