<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.ChangePasswordPanel">
    
    <Grid BackgroundColor="#80000000">
        <Border Style="{StaticResource LoginCard}">
            <VerticalStackLayout Spacing="24">
                <Label Text="Cambiar Clave"
                       Style="{StaticResource LoginTitle}"/>

                <Grid ColumnDefinitions="120,*"
                      RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="12"
                      RowSpacing="12">
                      
                    <Label Grid.Row="0" Grid.Column="0" Text="Usuario:" VerticalTextAlignment="Center" Style="{StaticResource FieldLabelDark}"/>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource InfoDisplayBorder}" Padding="10,0" HeightRequest="40">
                        <Label Text="{Binding UserName}" VerticalOptions="Center" TextColor="{DynamicResource Gray600}"/>
                    </Border>

                    <Label Grid.Row="1" Grid.Column="0" Text="Clave actual:" VerticalTextAlignment="Center" Style="{StaticResource FieldLabelDark}"/>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBox}">
                        <Entry Text="{Binding CurrentPassword}" IsPassword="True" Placeholder="Clave actual" VerticalOptions="Center"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Text="Clave nueva:" VerticalTextAlignment="Center" Style="{StaticResource FieldLabelDark}"/>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InputBox}">
                        <Entry Text="{Binding NewPassword}" IsPassword="True" Placeholder="Nueva clave" VerticalOptions="Center"/>
                    </Border>

                    <Label Grid.Row="3" Grid.Column="0" Text="Confirmar clave:" VerticalTextAlignment="Center" Style="{StaticResource FieldLabelDark}"/>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource InputBox}">
                        <Entry Text="{Binding ConfirmPassword}" IsPassword="True" Placeholder="Repita la clave" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <Label Text="{Binding ChangePasswordError}"
                       Style="{StaticResource ValidationErrorLabel}"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding HasChangePasswordError}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                    <Button Grid.Column="0" Text="Aceptar"
                            Command="{Binding ConfirmChangePasswordCommand}"
                            Style="{StaticResource PrimaryActionButton}"/>
                    <Button Grid.Column="1" Text="Cancelar"
                            Command="{Binding CancelChangePasswordCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>