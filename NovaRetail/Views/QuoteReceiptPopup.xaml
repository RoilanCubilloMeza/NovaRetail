<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.QuoteReceiptPopup">

    <Grid>
        <BoxView Color="#020617" Opacity="0.62"/>

        <Border BackgroundColor="#F8FAFC"
                Stroke="#D9E2EC"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22"
                MaximumWidthRequest="620"
                MaximumHeightRequest="900"
                Margin="22"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,12" Radius="28" Opacity="0.16" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                <!-- Header -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E3A5F"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22,22,0,0"
                        Padding="18,16">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="#2D5282"
                                Stroke="#3B6CB7"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="44" HeightRequest="44">
                            <Label Text="📋" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Proforma / Cotización"
                                   FontSize="17" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="Lista para imprimir, enviar o guardar."
                                   FontSize="11" TextColor="#BFDBFE" LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="#1D4ED8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="12,8"
                                VerticalOptions="Center">
                            <VerticalStackLayout Spacing="1">
                                <Label Text="COT." FontSize="9" TextColor="#DBEAFE" HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding OrderIDText}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="White" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- Body (scrollable) -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="660">
                    <VerticalStackLayout Padding="20,16,20,20" Spacing="0">

                        <!-- Ticket simulado -->
                        <Border BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                Padding="16,14">

                            <VerticalStackLayout Spacing="0">

                                <!-- Titulo recibo -->
                                <Label Text="Recibo Duplicado"
                                       FontSize="14" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#111827" Margin="0,0,0,4"/>

                                <!-- Datos tienda -->
                                <VerticalStackLayout IsVisible="{Binding HasStoreInfo}"
                                                     HorizontalOptions="Center" Spacing="1" Margin="0,0,0,4">
                                    <Label Text="{Binding StoreName}"
                                           FontSize="12" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" TextColor="#1F2937"/>
                                    <Label Text="{Binding StoreAddress}"
                                           FontSize="10" HorizontalTextAlignment="Center" TextColor="#6B7280"/>
                                    <Label Text="{Binding StorePhone}"
                                           FontSize="10" HorizontalTextAlignment="Center" TextColor="#6B7280"/>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,4"/>

                                <!-- Badge PROFORMA -->
                                <Border Stroke="#111827"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 4"
                                        HorizontalOptions="Center"
                                        Padding="16,4"
                                        Margin="0,6,0,4">
                                    <Label Text="Proforma"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="#111827" HorizontalTextAlignment="Center"/>
                                </Border>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,4"/>

                                <!-- Info del documento -->
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="2" ColumnSpacing="8" Margin="0,4,0,4">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Doc. Interno #:" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding OrderIDText}" FontSize="11" TextColor="#111827"/>

                                    <Label Grid.Row="1" Grid.Column="0" Text="Cédula:" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding ClientId}" FontSize="11" TextColor="#111827"/>

                                    <Label Grid.Row="2" Grid.Column="0" Text="Nombre:" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding ClientName}" FontSize="11" TextColor="#111827" LineBreakMode="TailTruncation"/>

                                    <Label Grid.Row="3" Grid.Column="0" Text="Fecha/Hora:" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding OrderDate}" FontSize="11" TextColor="#111827"/>

                                    <Label Grid.Row="4" Grid.Column="0" Text="Cajero:" FontSize="11" FontAttributes="Bold" TextColor="#374151" VerticalOptions="Center"/>
                                    <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                        <!-- Modo vista -->
                                        <Label Grid.Column="0"
                                               Text="{Binding CashierName}"
                                               FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsNotEditingCashier}"/>
                                        <Button Grid.Column="1"
                                                Text="✏️"
                                                Command="{Binding EditCashierCommand}"
                                                FontSize="10"
                                                BackgroundColor="Transparent"
                                                TextColor="#6B7280"
                                                Padding="0"
                                                HeightRequest="22"
                                                WidthRequest="26"
                                                IsVisible="{Binding IsNotEditingCashier}"/>
                                        <!-- Modo edición -->
                                        <Entry Grid.Column="0"
                                               Text="{Binding CashierName}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="#1D4ED8"
                                               BackgroundColor="#EFF6FF"
                                               IsVisible="{Binding IsEditingCashier}"
                                               ReturnCommand="{Binding EditCashierCommand}"
                                               Placeholder="Nombre del cajero"
                                               HeightRequest="28"/>
                                        <Button Grid.Column="1"
                                                Text="✓"
                                                Command="{Binding EditCashierCommand}"
                                                FontSize="11"
                                                BackgroundColor="#059669"
                                                TextColor="White"
                                                CornerRadius="4"
                                                Padding="0"
                                                HeightRequest="26"
                                                WidthRequest="26"
                                                IsVisible="{Binding IsEditingCashier}"/>
                                    </Grid>

                                    <Label Grid.Row="5" Grid.Column="0"
                                           Text="Vence:" FontSize="11" FontAttributes="Bold" TextColor="#374151"
                                           IsVisible="{Binding HasExpiration}"/>
                                    <Label Grid.Row="5" Grid.Column="1"
                                           Text="{Binding ExpirationText}" FontSize="11" TextColor="#D97706"
                                           IsVisible="{Binding HasExpiration}"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,4"/>

                                <!-- Encabezado columnas items -->
                                <Grid ColumnDefinitions="*,40,75,75" ColumnSpacing="4" Margin="0,2,0,2">
                                    <Label Grid.Column="0" Text="DESC/COD" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                    <Label Grid.Column="1" Text="CANT." FontSize="10" FontAttributes="Bold" TextColor="#6B7280" HorizontalTextAlignment="End"/>
                                    <Label Grid.Column="2" Text="PRECIO" FontSize="10" FontAttributes="Bold" TextColor="#6B7280" HorizontalTextAlignment="End"/>
                                    <Label Grid.Column="3" Text="TOTAL" FontSize="10" FontAttributes="Bold" TextColor="#6B7280" HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,2"/>

                                <!-- Lista de artículos -->
                                <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,40,75,75" ColumnSpacing="4"
                                                  RowDefinitions="Auto,Auto" Margin="0,3,0,0">
                                                <Label Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="#111827"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding QuantityText}"
                                                       FontSize="11" TextColor="#374151"
                                                       HorizontalTextAlignment="End"/>
                                                <Label Grid.Row="0" Grid.Column="2"
                                                       Text="{Binding UnitPriceColonesText}"
                                                       FontSize="11" TextColor="#374151"
                                                       HorizontalTextAlignment="End"/>
                                                <Label Grid.Row="0" Grid.Column="3"
                                                       Text="{Binding LineTotalText}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="#059669"
                                                       HorizontalTextAlignment="End"/>
                                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                                                     IsVisible="{Binding HasAnyDetail}"
                                                                     Spacing="1" Margin="0,1,0,3">
                                                    <Label Text="{Binding Code}"
                                                           FontSize="10" TextColor="#9CA3AF"/>
                                                    <Label Text="{Binding TaxRateText}"
                                                           FontSize="10" TextColor="#3B82F6"
                                                           IsVisible="{Binding HasTax}"/>
                                                    <Label Text="{Binding PriceChangeDetailText}"
                                                           FontSize="10" TextColor="#7C3AED"
                                                           IsVisible="{Binding HasOverridePrice}"/>
                                                    <Label Text="{Binding DiscountDetailText}"
                                                           FontSize="10" TextColor="#DC2626"
                                                           IsVisible="{Binding HasDiscount}"/>
                                                    <Label Text="{Binding ExonerationDetailText}"
                                                           FontSize="10" TextColor="#16A34A"
                                                           IsVisible="{Binding HasExoneration}"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,8,0,4"/>

                                <!-- Totales -->
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="2" ColumnSpacing="8">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Sub Total" FontSize="11" TextColor="#374151"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding SubtotalText}" FontSize="11" TextColor="#374151" HorizontalTextAlignment="End"/>

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="Descuentos" FontSize="11" TextColor="#DC2626"
                                           IsVisible="{Binding HasDiscount}"/>
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding DiscountText}" FontSize="11" TextColor="#DC2626"
                                           HorizontalTextAlignment="End"
                                           IsVisible="{Binding HasDiscount}"/>

                                    <Label Grid.Row="2" Grid.Column="0"
                                           Text="Exoneración" FontSize="11" TextColor="#16A34A"
                                           IsVisible="{Binding HasExoneration}"/>
                                    <Label Grid.Row="2" Grid.Column="1"
                                           Text="{Binding ExonerationText}" FontSize="11" TextColor="#16A34A"
                                           HorizontalTextAlignment="End"
                                           IsVisible="{Binding HasExoneration}"/>

                                    <Label Grid.Row="3" Grid.Column="0" Text="Imp.Ventas" FontSize="11" TextColor="#374151"/>
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding TaxText}" FontSize="11" TextColor="#374151" HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1.5" Color="#374151" Margin="0,6,0,4"/>

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="TOTAL" FontSize="14" FontAttributes="Bold" TextColor="#111827"/>
                                    <Label Grid.Column="1" Text="{Binding TotalColonesText}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="#1D4ED8" HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,6,0,4"/>

                                <!-- Sección pagos (ceros para proforma) -->
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="2" ColumnSpacing="8">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Deposito Pagos" FontSize="10" TextColor="#9CA3AF"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding CurrencyZeroText}" FontSize="10" TextColor="#9CA3AF" HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="Total Comprado" FontSize="10" TextColor="#9CA3AF"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding CurrencyZeroText}" FontSize="10" TextColor="#9CA3AF" HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Total Pendiente" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding TotalColonesText}" FontSize="11" FontAttributes="Bold" TextColor="#374151" HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="3" Grid.Column="0" Text="CAMBIO" FontSize="10" TextColor="#9CA3AF"/>
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding CurrencyZeroText}" FontSize="10" TextColor="#9CA3AF" HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="4" Grid.Column="0" Text="Saldo" FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8"/>
                                    <Label Grid.Row="4" Grid.Column="1" Text="{Binding TotalColonesText}" FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8" HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,8,0,6"/>

                                <!-- Footer mensajes -->
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="No se cambia ropa" FontSize="10" TextColor="#6B7280" HorizontalTextAlignment="Center"/>
                                    <Label Text="No se aceptan devoluciones sin factura" FontSize="10" TextColor="#6B7280" HorizontalTextAlignment="Center"/>
                                    <Label Text="No se aceptan devoluciones después de 45 días" FontSize="10" TextColor="#6B7280" HorizontalTextAlignment="Center"/>
                                    <Label Text=" " FontSize="6"/>
                                    <Label Text="¡Le Esperamos Pronto!" FontSize="12" FontAttributes="Bold" TextColor="#111827" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" Color="#D1D5DB" Margin="0,8,0,4"/>

                                <!-- Pie legal -->
                                <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                                    <Label Text="Documento emitido conforme lo establecido" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                    <Label Text="en la resolución de Factura Electrónica" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                    <Label Text="DGT-R-033-2019 del 20/06/2019" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                    <Label Text="Dirección General de Tributación" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                    <Label Text="Versión: 4.3 (Cabys)" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                    <Label Text="*** Generado por AVS Solutions ***" FontSize="9" TextColor="#9CA3AF" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Botones acción -->
                <Border Grid.Row="2"
                        BackgroundColor="#F1F5F9"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 0,0,22,22"
                        Padding="16,12">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="🖨️ Imprimir"
                                Command="{Binding PrintCommand}"
                                FontSize="12"
                                BackgroundColor="#1D4ED8"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="42"/>
                        <Button Grid.Column="1"
                                Text="💾 Guardar"
                                Command="{Binding SaveCommand}"
                                FontSize="12"
                                BackgroundColor="#059669"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="42"/>
                        <Button Grid.Column="2"
                                Text="✕ Cerrar"
                                Command="{Binding CloseCommand}"
                                FontSize="12"
                                BackgroundColor="#6B7280"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="42"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</ContentView>
