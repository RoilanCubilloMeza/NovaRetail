<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.ReceiptPopup">

    <Grid>
        <BoxView Color="#020617" Opacity="0.62"/>

        <Border BackgroundColor="#F8FAFC"
                Stroke="#D9E2EC"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22"
                MaximumWidthRequest="620"
                MaximumHeightRequest="900"
                Margin="22"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="#000000"
                        Offset="0,12"
                        Radius="28"
                        Opacity="0.16" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="0">

                <Border Grid.Row="0"
                        BackgroundColor="#0F172A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22,22,0,0"
                        Padding="18,16">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="#1E293B"
                                Stroke="#334155"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="44"
                                HeightRequest="44">
                            <Label Text="🧾"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Recibo duplicado"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Text="Resumen de la venta listo para imprimir, enviar o guardar."
                                   FontSize="11"
                                   TextColor="#BFDBFE"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="#1D4ED8"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="12,8"
                                VerticalOptions="Center">
                            <VerticalStackLayout Spacing="1">
                                <Label Text="DOC"
                                       FontSize="9"
                                       TextColor="#DBEAFE"
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding TransactionNumberText}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <ScrollView Grid.Row="1" MaximumHeightRequest="620">
                    <Grid Padding="20,18,20,20">
                        <Border BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18"
                                Padding="26,22"
                                HorizontalOptions="Center"
                                WidthRequest="430">
                            <Border.Shadow>
                                <Shadow Brush="#000000"
                                        Offset="0,6"
                                        Radius="18"
                                        Opacity="0.08" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="10">
                                <Label Text="Recibo Duplicado"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       HorizontalTextAlignment="Center"/>

                                <VerticalStackLayout Spacing="2"
                                                     HorizontalOptions="Center"
                                                     IsVisible="{Binding HasStoreInfo}">
                                    <Label Text="{Binding StoreName}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="{Binding StoreAddress}"
                                           FontSize="12"
                                           TextColor="#334155"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="WordWrap"/>
                                    <Label Text="{Binding StorePhone}"
                                           FontSize="12"
                                           TextColor="#334155"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="0,8,0,2"/>

                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8" RowSpacing="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Text="Doc. Interno #:"
                                           FontSize="11"
                                           TextColor="#0F172A"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding TransactionNumberText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>

                                    <Label Grid.Row="1" Grid.Column="0" Text="Cód. Cliente:"
                                           FontSize="11"
                                           TextColor="#0F172A"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding ClientId}"
                                           FontSize="11"
                                           TextColor="#0F172A"/>

                                    <Label Grid.Row="2" Grid.Column="0" Text="Nombre:"
                                           FontSize="11"
                                           TextColor="#0F172A"/>
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding ClientName}"
                                           FontSize="11"
                                           TextColor="#0F172A"
                                           LineBreakMode="WordWrap"/>

                                    <Label Grid.Row="3" Grid.Column="0" Text="Fecha/Hora:"
                                           FontSize="11"
                                           TextColor="#0F172A"/>
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding TransactionDate}"
                                           FontSize="11"
                                           TextColor="#0F172A"/>

                                    <Label Grid.Row="4" Grid.Column="0" Text="Cajero:"
                                           FontSize="11"
                                           TextColor="#0F172A"/>
                                    <Grid Grid.Row="4" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="{Binding CashierName}"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding RegisterText}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>
                                </Grid>

                                <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="0,8,0,0"/>

                                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                      ColumnSpacing="6"
                                      Padding="0,2,0,0">
                                    <Label Grid.Column="0" Text="DESC/COD"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"/>
                                    <Label Grid.Column="1" Text="CANT."
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="End"
                                           MinimumWidthRequest="42"/>
                                    <Label Grid.Column="2" Text="PRECIO"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="End"
                                           MinimumWidthRequest="84"/>
                                    <Label Grid.Column="3" Text="TOTAL"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="End"
                                           MinimumWidthRequest="84"/>
                                </Grid>

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                                     Spacing="0"
                                                     Padding="0,4,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <VerticalStackLayout Spacing="2" Padding="0,5,0,5">
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                                                        <Label Text="{Binding DisplayName}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="#0F172A"
                                                               LineBreakMode="WordWrap"/>
                                                        <HorizontalStackLayout Spacing="6">
                                                            <Label Text="{Binding Code}"
                                                                   FontSize="10"
                                                                   TextColor="#334155"/>
                                                            <Label Text="{Binding TaxRateText}"
                                                                   FontSize="10"
                                                                   TextColor="#334155"
                                                                   IsVisible="{Binding HasTax}"/>
                                                        </HorizontalStackLayout>
                                                    </VerticalStackLayout>

                                                    <Label Grid.Column="1"
                                                           Text="{Binding QuantityText}"
                                                           FontSize="11"
                                                           TextColor="#0F172A"
                                                           HorizontalTextAlignment="End"
                                                           VerticalOptions="Start"
                                                           MinimumWidthRequest="42"/>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding UnitPriceColonesText}"
                                                           FontSize="11"
                                                           TextColor="#0F172A"
                                                           HorizontalTextAlignment="End"
                                                           VerticalOptions="Start"
                                                           MinimumWidthRequest="84"/>
                                                    <Label Grid.Column="3"
                                                           Text="{Binding LineTotalText}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#0F172A"
                                                           HorizontalTextAlignment="End"
                                                           VerticalOptions="Start"
                                                           MinimumWidthRequest="84"/>
                                                </Grid>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="0,8,0,0"/>

                                <VerticalStackLayout Spacing="3">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Sub Total"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding SubtotalText}"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasDiscount}">
                                        <Label Grid.Column="0" Text="Descuentos"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding DiscountText}"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasExoneration}">
                                        <Label Grid.Column="0" Text="Exoneración"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding ExonerationText}"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Imp.Ventas"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding TaxText}"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Total"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding TotalColonesText}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="0,8,0,0"/>

                                <VerticalStackLayout Spacing="2">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding TenderEntregadoText}"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="{Binding TotalColonesText}"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="CAMBIO"
                                               FontSize="11"
                                               TextColor="#0F172A"/>
                                        <Label Grid.Column="1" Text="&#x20A1;0.00"
                                               FontSize="11"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End"/>
                                    </Grid>
                                </VerticalStackLayout>

                                <Label Text="----------------------------------------"
                                       FontSize="11"
                                       TextColor="#64748B"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,10,0,0"/>

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="No se cambia ropa"
                                           FontSize="11"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="No se aceptan devoluciones sin factura"
                                           FontSize="11"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="No se aceptan devoluciones después de 45 días"
                                           FontSize="11"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <Label Text="----------------------------------------"
                                       FontSize="11"
                                       TextColor="#64748B"
                                       HorizontalTextAlignment="Center"/>

                                <Label Text="¡Le Esperamos Pronto!"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#0F172A"
                                       HorizontalTextAlignment="Center"
                                       Margin="0,2,0,0"/>

                                <VerticalStackLayout Padding="14,14,14,0" Spacing="2">
                                    <Label Text="Documento emitido conforme lo establecido"
                                           FontSize="9"
                                           TextColor="#475569"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="en la resolución de Factura Electrónica"
                                           FontSize="9"
                                           TextColor="#475569"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="DGT-R-053-2019 del 20/06/2019"
                                           FontSize="9"
                                           TextColor="#475569"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="de la Dirección General de Tributación"
                                           FontSize="9"
                                           TextColor="#475569"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="Versión: 4.3 (Cabys)"
                                           FontSize="9"
                                           TextColor="#475569"
                                           HorizontalTextAlignment="Center"/>
                                    <Label Text="*** Generado por AVS Solutions ***"
                                           FontSize="9"
                                           TextColor="#0F172A"
                                           HorizontalTextAlignment="Center"
                                           Margin="0,4,0,0"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </ScrollView>

                <Border Grid.Row="2"
                        BackgroundColor="#F8FAFC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,22,22"
                        Padding="18,16">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="🖨️ Imprimir"
                                    Command="{Binding PrintCommand}"
                                    BackgroundColor="#2563EB"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    Padding="8,0"
                                    IsEnabled="{Binding IsNotBusy}"/>

                            <Button Grid.Column="1"
                                    Text="✉️ Enviar"
                                    Command="{Binding EmailCommand}"
                                    BackgroundColor="#059669"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    Padding="8,0"
                                    IsEnabled="{Binding IsNotBusy}"/>

                            <Button Grid.Column="2"
                                    Text="💾 Guardar"
                                    Command="{Binding SaveCommand}"
                                    BackgroundColor="#7C3AED"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="44"
                                    Padding="8,0"
                                    IsEnabled="{Binding IsNotBusy}"/>
                        </Grid>

                        <VerticalStackLayout Spacing="4"
                                             HorizontalOptions="Center"
                                             IsVisible="{Binding IsBusy}">
                            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                               IsVisible="{Binding IsBusy}"
                                               HeightRequest="22"
                                               Color="#2563EB"
                                               HorizontalOptions="Center"/>
                            <Label Text="Procesando acción..."
                                   FontSize="10"
                                   TextColor="#64748B"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <Button Text="Cerrar"
                                Command="{Binding CloseCommand}"
                                BackgroundColor="#0F172A"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="10"
                                HeightRequest="46"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Border>
    </Grid>
</ContentView>



