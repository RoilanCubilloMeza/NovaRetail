<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.ReceiptPopup">

    <Grid>
        <BoxView Color="#000000" Opacity="0.6"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="0"
                MaximumWidthRequest="420" MaximumHeightRequest="780"
                Margin="16"
                HorizontalOptions="Center"
                VerticalOptions="Center">

            <Grid RowDefinitions="Auto, *, Auto, Auto" RowSpacing="0">

                <!-- Header bar -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 8,8,0,0"
                        Padding="16,10">
                    <Label Text="Recibo Duplicado"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <!-- Receipt content -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="420">
                    <VerticalStackLayout Spacing="0" BackgroundColor="White">

                        <!-- Store info -->
                        <VerticalStackLayout Spacing="2" Padding="16,12,16,8"
                                             HorizontalOptions="Center"
                                             IsVisible="{Binding HasStoreInfo}">
                            <Label Text="{Binding StoreName}"
                                   FontSize="13" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" TextColor="#0F172A"/>
                            <Label Text="{Binding StoreAddress}"
                                   FontSize="10" HorizontalTextAlignment="Center"
                                   TextColor="#475569" IsVisible="{Binding HasStoreInfo}"/>
                            <Label Text="{Binding StorePhone}"
                                   FontSize="10" HorizontalTextAlignment="Center"
                                   TextColor="#475569"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="16,0"/>

                        <!-- Transaction info -->
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6"
                              Padding="16,8" RowSpacing="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Text="Doc. Interno #:"
                                   FontSize="10" TextColor="#64748B"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding TransactionNumberText}"
                                   FontSize="10" FontAttributes="Bold" TextColor="#0F172A"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Cód. Cliente:"
                                   FontSize="10" TextColor="#64748B"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding ClientId}"
                                   FontSize="10" TextColor="#0F172A"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Nombre:"
                                   FontSize="10" TextColor="#64748B"/>
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding ClientName}"
                                   FontSize="10" TextColor="#0F172A"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Fecha/Hora:"
                                   FontSize="10" TextColor="#64748B"/>
                            <Label Grid.Row="3" Grid.Column="1"
                                   Text="{Binding TransactionDate}"
                                   FontSize="10" TextColor="#0F172A"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Cajero:"
                                   FontSize="10" TextColor="#64748B"/>
                            <Grid Grid.Row="4" Grid.Column="1"
                                  ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <Label Grid.Column="0"
                                       Text="{Binding CashierName}"
                                       FontSize="10" TextColor="#0F172A"/>
                                <Label Grid.Column="1"
                                       Text="{Binding RegisterText}"
                                       FontSize="10" TextColor="#64748B"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                        </Grid>

                        <!-- Items header -->
                        <BoxView HeightRequest="1" BackgroundColor="#64748B" Margin="16,0"/>
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto"
                              Padding="16,4,16,4" ColumnSpacing="4">
                            <Label Grid.Column="0" Text="DESC/COD"
                                   FontSize="9" FontAttributes="Bold" TextColor="#475569"/>
                            <Label Grid.Column="1" Text="CANT."
                                   FontSize="9" FontAttributes="Bold" TextColor="#475569"
                                   HorizontalTextAlignment="End" MinimumWidthRequest="34"/>
                            <Label Grid.Column="2" Text="PRECIO"
                                   FontSize="9" FontAttributes="Bold" TextColor="#475569"
                                   HorizontalTextAlignment="End" MinimumWidthRequest="68"/>
                            <Label Grid.Column="3" Text="TOTAL"
                                   FontSize="9" FontAttributes="Bold" TextColor="#475569"
                                   HorizontalTextAlignment="End" MinimumWidthRequest="68"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#64748B" Margin="16,0"/>

                        <!-- Items list -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                             Spacing="0" Padding="16,2,16,2">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="0" Padding="0,4,0,4">
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto"
                                              ColumnSpacing="4">
                                            <Label Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="10" TextColor="#0F172A"
                                                   LineBreakMode="WordWrap"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding QuantityText}"
                                                   FontSize="10" TextColor="#0F172A"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Start"
                                                   MinimumWidthRequest="34"/>
                                            <Label Grid.Column="2"
                                                   Text="{Binding UnitPriceColonesText}"
                                                   FontSize="10" TextColor="#0F172A"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Start"
                                                   MinimumWidthRequest="68"/>
                                            <Label Grid.Column="3"
                                                   Text="{Binding LineTotalText}"
                                                   FontSize="10" FontAttributes="Bold"
                                                   TextColor="#0F172A"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Start"
                                                   MinimumWidthRequest="68"/>
                                        </Grid>
                                        <Label Text="{Binding Code}"
                                               FontSize="9" TextColor="#94A3B8"/>
                                        <Label Text="{Binding TaxRateText}"
                                               FontSize="9" TextColor="#94A3B8"
                                               IsVisible="{Binding HasTax}"/>
                                        <BoxView HeightRequest="1" BackgroundColor="#F1F5F9"
                                                 Margin="0,3,0,0"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Totals -->
                        <BoxView HeightRequest="1" BackgroundColor="#64748B" Margin="16,0"/>
                        <VerticalStackLayout Padding="16,6" Spacing="4">

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Subtotal"
                                       FontSize="10" TextColor="#475569"/>
                                <Label Grid.Column="1" Text="{Binding SubtotalText}"
                                       FontSize="10" TextColor="#0F172A"
                                       HorizontalTextAlignment="End"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasDiscount}">
                                <Label Grid.Column="0" Text="Descuentos"
                                       FontSize="10" TextColor="#EF4444"/>
                                <Label Grid.Column="1" Text="{Binding DiscountText}"
                                       FontSize="10" TextColor="#EF4444"
                                       HorizontalTextAlignment="End"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasExoneration}">
                                <Label Grid.Column="0" Text="Exoneración"
                                       FontSize="10" TextColor="#0891B2"/>
                                <Label Grid.Column="1" Text="{Binding ExonerationText}"
                                       FontSize="10" TextColor="#0891B2"
                                       HorizontalTextAlignment="End"/>
                            </Grid>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Imp.Ventas"
                                       FontSize="10" TextColor="#475569"/>
                                <Label Grid.Column="1" Text="{Binding TaxText}"
                                       FontSize="10" TextColor="#0F172A"
                                       HorizontalTextAlignment="End"/>
                            </Grid>

                            <BoxView HeightRequest="1" BackgroundColor="#CBD5E1"/>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Total"
                                       FontSize="14" FontAttributes="Bold" TextColor="#0F172A"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding TotalColonesText}"
                                       FontSize="14" FontAttributes="Bold" TextColor="#065F46"
                                       HorizontalTextAlignment="End"/>
                            </Grid>

                        </VerticalStackLayout>

                        <!-- Payment -->
                        <BoxView HeightRequest="1" BackgroundColor="#CBD5E1" Margin="16,0"/>
                        <VerticalStackLayout Padding="16,6" Spacing="4">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="{Binding TenderEntregadoText}"
                                       FontSize="10" TextColor="#475569"/>
                                <Label Grid.Column="1" Text="{Binding TotalColonesText}"
                                       FontSize="10" TextColor="#0F172A"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="CAMBIO"
                                       FontSize="10" TextColor="#475569"/>
                                <Label Grid.Column="1" Text="&#x20A1;0.00"
                                       FontSize="10" TextColor="#0F172A"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Footer messages -->
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="16,4"/>
                        <VerticalStackLayout Padding="16,6" Spacing="2">
                            <Label Text="No se cambia ropa"
                                   FontSize="9" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                            <Label Text="No se aceptan devoluciones sin factura"
                                   FontSize="9" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                            <Label Text="No se aceptan devoluciones después de 45 días"
                                   FontSize="9" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                            <Label Text="¡Le Esperamos Pronto!"
                                   FontSize="10" FontAttributes="Bold" TextColor="#0F172A"
                                   HorizontalTextAlignment="Center" Margin="0,4,0,4"/>
                        </VerticalStackLayout>

                        <!-- DGT / Legal -->
                        <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="16,0"/>
                        <VerticalStackLayout Padding="16,6,16,12" Spacing="1">
                            <Label Text="Documento emitido conforme lo establecido"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
                            <Label Text="en la resolución de Factura Electrónica"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
                            <Label Text="DGT-R-053-2019 del 20/06/2019"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
                            <Label Text="de la Dirección General de Tributación"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
                            <Label Text="Versión: 4.3 (Cabys)"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
                            <Label Text="*** Generado por AVS Solutions ***"
                                   FontSize="8" TextColor="#94A3B8" HorizontalTextAlignment="Center"
                                   Margin="0,4,0,0"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action bar + Close -->
                <Border Grid.Row="2"
                        BackgroundColor="#F8FAFC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,8,8"
                        Padding="16,10">
                    <VerticalStackLayout Spacing="8">

                        <!-- Action buttons row -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                            <!-- Print -->
                            <Button Grid.Column="0"
                                    Text="🖨️ Imprimir"
                                    Command="{Binding PrintCommand}"
                                    BackgroundColor="#3B82F6"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="6"
                                    HeightRequest="38"
                                    Padding="4,0"
                                    IsEnabled="{Binding IsNotBusy}"/>
                            <Button Grid.Column="1"
                                    Text="✉️ Enviar"
                                    Command="{Binding EmailCommand}"
                                    BackgroundColor="#059669"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="6"
                                    HeightRequest="38"
                                    Padding="4,0"
                                    IsEnabled="{Binding IsNotBusy}"/>

                            <!-- Save -->
                            <Button Grid.Column="2"
                                    Text="💾 Guardar"
                                    Command="{Binding SaveCommand}"
                                    BackgroundColor="#7C3AED"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    CornerRadius="6"
                                    HeightRequest="38"
                                    Padding="4,0"
                                    IsEnabled="{Binding IsNotBusy}"/>
                        </Grid>

                        <!-- Busy indicator -->
                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HeightRequest="20"
                                           Color="#3B82F6"
                                           HorizontalOptions="Center"/>

                        <!-- Close -->
                        <Button Text="Cerrar"
                                Command="{Binding CloseCommand}"
                                BackgroundColor="#1E293B"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="6"
                                HeightRequest="40"/>

                    </VerticalStackLayout>
                </Border>

            </Grid>
        </Border>
    </Grid>
</ContentView>



