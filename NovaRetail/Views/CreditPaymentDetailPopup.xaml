<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CreditPaymentDetailPopup">

    <Grid>
        <!-- Backdrop -->
        <BoxView Color="#000000" Opacity="0.55"/>

        <!-- MAIN POPUP — Ventana fija, solo la tabla hace scroll -->
        <Grid BackgroundColor="White"
              MaximumWidthRequest="1150"
              HeightRequest="750"
              Margin="24"
              HorizontalOptions="Center"
              VerticalOptions="Center"
              RowDefinitions="Auto,Auto,1,Auto,1,Auto,Auto,*,1,Auto,Auto,Auto,Auto">

            <!-- Row 0: Header -->
            <Grid Grid.Row="0" BackgroundColor="#334155" Padding="16,12" ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Cuenta por Cobrar" FontSize="17" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="{Binding CustomerName}" FontSize="11" TextColor="#CBD5E1"/>
                </VerticalStackLayout>
                <Label Grid.Column="1"
                       Text="{Binding AccountNumber, StringFormat='# {0}'}"
                       FontSize="14" FontAttributes="Bold" TextColor="#38BDF8"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Row 1: Summary -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Padding="16,12" ColumnSpacing="8"
                  BackgroundColor="#F8FAFC">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Total adeudado" FontSize="9" TextColor="#94A3B8" FontAttributes="Bold"/>
                    <Label Text="{Binding TotalDebtText}" FontSize="15" FontAttributes="Bold" TextColor="#EF4444"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Crédito total" FontSize="9" TextColor="#94A3B8" FontAttributes="Bold"/>
                    <Label Text="{Binding CreditLimitText}" FontSize="15" FontAttributes="Bold" TextColor="#22C55E"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Spacing="2">
                    <Label Text="Balance" FontSize="9" TextColor="#94A3B8" FontAttributes="Bold"/>
                    <Label Text="{Binding BalanceText}" FontSize="15" FontAttributes="Bold" TextColor="#3B82F6"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Row 2: Separator -->
            <BoxView Grid.Row="2" Color="#E2E8F0"/>

            <!-- Row 3: Reference / Description -->
            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,16,Auto,*" Padding="16,10" ColumnSpacing="6">
                <Label Grid.Column="0" Text="Referencia:" FontSize="12" TextColor="#64748B" VerticalOptions="Center"/>
                <Entry Grid.Column="1" Text="{Binding Referencia}"
                       Placeholder="Referencia" FontSize="12" TextColor="#0F172A"
                       BackgroundColor="#F1F5F9" VerticalOptions="Center"/>
                <Label Grid.Column="3" Text="Descripción:" FontSize="12" TextColor="#64748B" VerticalOptions="Center"/>
                <Entry Grid.Column="4" Text="{Binding Descripcion}"
                       Placeholder="Descripción" FontSize="12" TextColor="#0F172A"
                       BackgroundColor="#F1F5F9" VerticalOptions="Center"/>
            </Grid>

            <!-- Row 4: Separator -->
            <BoxView Grid.Row="4" Color="#E2E8F0"/>

            <!-- Row 5: Toolbar -->
            <Grid Grid.Row="5" ColumnDefinitions="Auto,*,Auto,Auto" Padding="16,8" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Cuentas por cobrar abiertas"
                       FontSize="13" FontAttributes="Bold" TextColor="#1E293B"
                       VerticalOptions="Center"/>
                <Button Grid.Column="2" Text="Seleccionar todo"
                        Command="{Binding SelectAllCommand}"
                        FontSize="11" FontAttributes="Bold"
                        TextColor="#3B82F6" BackgroundColor="#EFF6FF"
                        BorderColor="#BFDBFE" BorderWidth="1"
                        CornerRadius="4" Padding="10,4" HeightRequest="30"/>
                <Button Grid.Column="3" Text="Limpiar"
                        Command="{Binding DeselectAllCommand}"
                        FontSize="11" FontAttributes="Bold"
                        TextColor="#64748B" BackgroundColor="#F1F5F9"
                        BorderColor="#CBD5E1" BorderWidth="1"
                        CornerRadius="4" Padding="10,4" HeightRequest="30"/>
            </Grid>

            <!-- Row 6: Table header -->
            <Grid Grid.Row="6" BackgroundColor="#334155" Padding="6,7" Margin="12,0"
                  ColumnDefinitions="78,78,78,82,*,44,88,100,100,110,36"
                  ColumnSpacing="4">
                <Label Grid.Column="0"  Text="Fecha Pub."  FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="1"  Text="F. Venc."    FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="2"  Text="Tipo L.M."   FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="3"  Text="Tipo Doc."   FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="4"  Text="Descripción" FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="5"  Text="Store"       FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0" HorizontalTextAlignment="Center"/>
                <Label Grid.Column="6"  Text="Referencia"  FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0"/>
                <Label Grid.Column="7"  Text="Monto"       FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0" HorizontalTextAlignment="End"/>
                <Label Grid.Column="8"  Text="Balance"     FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0" HorizontalTextAlignment="End"/>
                <Label Grid.Column="9"  Text="Monto a aplicar" FontSize="9.5" FontAttributes="Bold" TextColor="#E2E8F0" HorizontalTextAlignment="End"/>
                <Label Grid.Column="10" Text="&#x2713;"    FontSize="10"  FontAttributes="Bold" TextColor="#E2E8F0" HorizontalTextAlignment="Center"/>
            </Grid>

            <!-- Row 7: Scrollable table rows (toma todo el espacio restante) -->
            <ScrollView Grid.Row="7" Margin="12,0" VerticalOptions="Fill">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding OpenEntries}"
                                     Spacing="0">
                    <BindableLayout.EmptyView>
                        <Label Text="No hay cuentas abiertas."
                               FontSize="12" TextColor="#94A3B8"
                               HorizontalTextAlignment="Center" Margin="0,24"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="78,78,78,82,*,44,88,100,100,110,36"
                                  Padding="6,5" ColumnSpacing="4" BackgroundColor="White">
                                <BoxView Grid.ColumnSpan="11" Color="#F8FAFC"
                                         Opacity="0.6" InputTransparent="True"/>
                                <Label Grid.Column="0"  Text="{Binding PostingDate}"      FontSize="10" TextColor="#334155" VerticalOptions="Center" LineBreakMode="NoWrap"/>
                                <Label Grid.Column="1"  Text="{Binding DueDate}"          FontSize="10" TextColor="#334155" VerticalOptions="Center" LineBreakMode="NoWrap"/>
                                <Label Grid.Column="2"  Text="{Binding LedgerTypeName}"   FontSize="10" TextColor="#334155" VerticalOptions="Center"/>
                                <Label Grid.Column="3"  Text="{Binding DocumentTypeName}" FontSize="10" TextColor="#334155" VerticalOptions="Center"/>
                                <Label Grid.Column="4"  Text="{Binding Description}"      FontSize="10" TextColor="#334155" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                                <Label Grid.Column="5"  Text="{Binding StoreID}"          FontSize="10" TextColor="#334155" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                <Label Grid.Column="6"  Text="{Binding Reference}"        FontSize="10" TextColor="#334155" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
                                <Label Grid.Column="7"  Text="{Binding AmountText}"       FontSize="10" TextColor="#334155" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="End"/>
                                <Label Grid.Column="8"  Text="{Binding BalanceText}"      FontSize="10" TextColor="#EF4444" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="End"/>
                                <Entry Grid.Column="9"  Text="{Binding AmountToApplyText}"
                                       Keyboard="Numeric" FontSize="10" TextColor="#0F172A"
                                       BackgroundColor="#F1F5F9" HorizontalTextAlignment="End"
                                       VerticalOptions="Center" HeightRequest="28"/>
                                <CheckBox Grid.Column="10" IsChecked="{Binding IsSelected}"
                                          Color="#3B82F6" VerticalOptions="Center" HorizontalOptions="Center"/>
                                <BoxView Grid.ColumnSpan="11" HeightRequest="1" Color="#F1F5F9"
                                         VerticalOptions="End" InputTransparent="True"/>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Row 8: Separator -->
            <BoxView Grid.Row="8" Color="#E2E8F0" Margin="12,0"/>

            <!-- Row 9: Totals -->
            <Grid Grid.Row="9" ColumnDefinitions="*,Auto,Auto" Padding="16,10" ColumnSpacing="12"
                  BackgroundColor="#F8FAFC">
                <Label Grid.Column="0" Text="{Binding SelectedCountText}"
                       FontSize="12" TextColor="#64748B" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="Total a aplicar:"
                       FontSize="13" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                <Label Grid.Column="2" Text="{Binding TotalToApplyText}"
                       FontSize="17" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center"/>
            </Grid>

            <!-- Row 10: Error -->
            <Label Grid.Row="10" Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   BackgroundColor="#FEF2F2" TextColor="#DC2626"
                   FontSize="12" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" Padding="10,8"/>

            <!-- Row 11: Success -->
            <Label Grid.Row="11" Text="Abono registrado exitosamente."
                   IsVisible="{Binding ShowSuccess}"
                   BackgroundColor="#F0FDF4" TextColor="#15803D"
                   FontSize="12" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" Padding="10,8"/>

            <!-- Row 12: Footer -->
            <Grid Grid.Row="12" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10"
                  Padding="16,10" BackgroundColor="#F1F5F9">
                <Button Grid.Column="0" Text="&#x2190; Volver"
                        Command="{Binding BackCommand}"
                        FontSize="12" FontAttributes="Bold"
                        TextColor="#475569" BackgroundColor="White"
                        BorderColor="#CBD5E1" BorderWidth="1"
                        CornerRadius="6" Padding="14,0" HeightRequest="38"/>
                <Button Grid.Column="2" Text="Cerrar"
                        Command="{Binding CloseCommand}"
                        FontSize="12" FontAttributes="Bold"
                        TextColor="White" BackgroundColor="#EF4444"
                        CornerRadius="6" Padding="14,0" HeightRequest="38"/>
                <Grid Grid.Column="3">
                    <Button Text="Aplicar Abono"
                            Command="{Binding ConfirmCommand}"
                            FontSize="12" FontAttributes="Bold"
                            TextColor="White" BackgroundColor="#16A34A"
                            CornerRadius="6" Padding="20,0" HeightRequest="38"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="#16A34A"
                                       WidthRequest="24" HeightRequest="24"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
            </Grid>

        </Grid>

        <!-- ======= PAYMENT TYPE DIALOG ======= -->
        <Grid IsVisible="{Binding ShowPaymentTypeDialog}"
              InputTransparent="False" ZIndex="10">
            <BoxView Color="#000000" Opacity="0.5"/>
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1"
                    MaximumWidthRequest="420"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="0" Shadow="{x:Null}">
                <VerticalStackLayout Spacing="0">
                    <Border BackgroundColor="#1E293B" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14,14,0,0" Padding="20,14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="&#x1F4B3;" FontSize="18" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="&#x00BF;Cómo desea aplicar el pago?"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center" IsVisible="{Binding ShowPaymentOptions}"/>
                            <Label Grid.Column="1" Text="Pago Parcial"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center" IsVisible="{Binding ShowPartialInput}"/>
                        </Grid>
                    </Border>
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0" Padding="16,12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding PendingEntryReference}"
                                   FontSize="13" FontAttributes="Bold" TextColor="#334155" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding PendingEntryBalanceText}"
                                   FontSize="16" FontAttributes="Bold" TextColor="#DC2626" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <BoxView HeightRequest="1" Color="#E2E8F0"/>
                    <!-- Step 1: Payment options -->
                    <VerticalStackLayout Spacing="10" Padding="20,16" IsVisible="{Binding ShowPaymentOptions}">
                        <Border BackgroundColor="#F0FDF4" Stroke="#86EFAC"
                                StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PayTotalCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#16A34A" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8" WidthRequest="40" HeightRequest="40">
                                    <Label Text="&#x2705;" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Pago Total" FontSize="14" FontAttributes="Bold" TextColor="#15803D"/>
                                    <Label Text="Aplicar el monto total del balance" FontSize="11" TextColor="#64748B"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                        <Border BackgroundColor="#EFF6FF" Stroke="#93C5FD"
                                StrokeThickness="1.5" StrokeShape="RoundRectangle 10" Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PayPartialCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#2563EB" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8" WidthRequest="40" HeightRequest="40">
                                    <Label Text="&#x270F;" FontSize="18" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Pago Parcial" FontSize="14" FontAttributes="Bold" TextColor="#1D4ED8"/>
                                    <Label Text="Ingresar el monto manualmente" FontSize="11" TextColor="#64748B"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                    <!-- Step 2: Partial amount input -->
                    <VerticalStackLayout Spacing="12" Padding="20,16" IsVisible="{Binding ShowPartialInput}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Balance de la factura:"
                                   FontSize="13" TextColor="#475569" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding PendingEntryBalanceText}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                        </Grid>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Monto a pagar:" FontSize="12" FontAttributes="Bold" TextColor="#334155"/>
                            <Border BackgroundColor="White" Stroke="#93C5FD"
                                    StrokeThickness="2" StrokeShape="RoundRectangle 8"
                                    HeightRequest="44" Padding="12,0">
                                <Entry Text="{Binding PartialAmountText}"
                                       Keyboard="Numeric" FontSize="16" FontAttributes="Bold"
                                       TextColor="#0F172A" BackgroundColor="Transparent"
                                       Placeholder="0.00" PlaceholderColor="#94A3B8"
                                       HorizontalTextAlignment="End" VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                        <Border BackgroundColor="#FEF2F2" Stroke="#FECACA"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Restante por pagar:"
                                       FontSize="13" TextColor="#DC2626" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding RemainingBalanceText}"
                                       FontSize="16" FontAttributes="Bold" TextColor="#DC2626" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,4,0,0">
                            <Border Grid.Column="0" BackgroundColor="#F1F5F9" Stroke="#CBD5E1"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                    HeightRequest="38" Padding="14,0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BackToPaymentOptionsCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="&#x2190; Volver" FontSize="12" FontAttributes="Bold"
                                       TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Border Grid.Column="2" StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    HeightRequest="38" Padding="14,0" BackgroundColor="#2563EB">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ConfirmPartialCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Aplicar Monto" FontSize="12" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0"
                            StrokeShape="RoundRectangle 0,0,14,14" Padding="16,10">
                        <Label Text="Cancelar" FontSize="12" TextColor="#64748B"
                               FontAttributes="Bold" HorizontalTextAlignment="Center" TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelPaymentDialogCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ======= CONFIRM PAYMENT DIALOG ======= -->
        <Grid IsVisible="{Binding ShowConfirmDialog}"
              InputTransparent="False" ZIndex="20">
            <BoxView Color="#000000" Opacity="0.55"/>
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 14" Stroke="#E2E8F0" StrokeThickness="1"
                    MaximumWidthRequest="480"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="0" Shadow="{x:Null}">
                <VerticalStackLayout Spacing="0">
                    <Border BackgroundColor="#1E293B" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14,14,0,0" Padding="20,14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="&#x1F9FE;" FontSize="18" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Confirmar Abono"
                                   FontSize="16" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0" Padding="20,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding CustomerName, StringFormat='Cliente: {0}'}"
                                   FontSize="12" TextColor="#475569"/>
                            <Label Text="{Binding ConfirmSummaryText}"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Label Text="{Binding TotalToApplyText, StringFormat='Monto total: {0}'}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#16A34A"/>
                        </VerticalStackLayout>
                    </Border>
                    <BoxView HeightRequest="1" Color="#E2E8F0"/>
                    <VerticalStackLayout Spacing="8" Padding="20,14">
                        <Label Text="Seleccione el método de pago:" FontSize="13"
                               FontAttributes="Bold" TextColor="#1E293B"/>
                        <FlexLayout Wrap="Wrap" JustifyContent="Start"
                                    BindableLayout.ItemsSource="{Binding PaymentTenders}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8" Padding="14,10"
                                            StrokeShape="RoundRectangle 8" StrokeThickness="2"
                                            BackgroundColor="White" Stroke="#CBD5E1">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectConfirmTenderCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding DisplayText}" FontSize="12" FontAttributes="Bold"
                                               TextColor="#334155" VerticalOptions="Center"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                        <Label Text="{Binding SelectedTenderText, StringFormat='&#x25B6; {0}'}"
                               FontSize="12" TextColor="#2563EB" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <BoxView HeightRequest="1" Color="#E2E8F0"/>
                    <Border BackgroundColor="#EFF6FF" StrokeThickness="0" Padding="20,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Se creará:" FontSize="11" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Label Text="&#x2022; Registro de pago (AR_LedgerEntry)" FontSize="10" TextColor="#475569"/>
                            <Label Text="&#x2022; Aplicación por cada factura seleccionada" FontSize="10" TextColor="#475569"/>
                            <Label Text="&#x2022; Actualización de balances" FontSize="10" TextColor="#475569"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border BackgroundColor="#FEF2F2" Stroke="#FCA5A5" StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,8" Margin="20,8,20,0"
                            IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}" FontSize="11" FontAttributes="Bold"
                               TextColor="#DC2626" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Grid ColumnDefinitions="*,10,*" Padding="20,14">
                        <Border Grid.Column="0" BackgroundColor="#F1F5F9" Stroke="#CBD5E1"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                HeightRequest="42" Padding="12,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelConfirmDialogCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cancelar" FontSize="13" FontAttributes="Bold"
                                   TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#16A34A" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8" HeightRequest="42" Padding="12,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding FinalConfirmCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6"
                                  HorizontalOptions="Center" VerticalOptions="Center">
                                <ActivityIndicator Grid.Column="0"
                                                   IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                                   Color="White" WidthRequest="16" HeightRequest="16"/>
                                <Label Grid.Column="0" Text="&#x1F4B5;" FontSize="14" VerticalOptions="Center"
                                       IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                                <Label Grid.Column="1" Text="Confirmar Pago"
                                       FontSize="13" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentView>
