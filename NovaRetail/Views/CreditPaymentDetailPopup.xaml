<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CreditPaymentDetailPopup">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                MaximumWidthRequest="1200"
                MaximumHeightRequest="820"
                Margin="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Shadow="{x:Null}">

            <Grid RowDefinitions="Auto, *, Auto, Auto" RowSpacing="0">

                <!-- ══════ Row 0: Title ══════ -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14,14,0,0"
                        Padding="20,14">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="&#x1F4B0;" FontSize="20" VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Cuenta por Cobrar"
                                   FontSize="18" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{Binding CustomerName, StringFormat='Cliente: {0}'}"
                                   FontSize="12" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="{Binding AccountNumber, StringFormat='Cuenta: {0}'}"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="#60A5FA"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ══════ Row 1: Content ══════ -->
                <ScrollView Grid.Row="1" Padding="0">
                    <VerticalStackLayout Spacing="0">

                        <!-- ── Summary cards ── -->
                        <Grid ColumnDefinitions="*, *, *"
                              ColumnSpacing="12"
                              Padding="20,16,20,10">

                            <!-- Total adeudado -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#FEF2F2"
                                    Stroke="#FECACA" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14,10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Total adeudado" FontSize="11" TextColor="#475569"/>
                                    <Label Text="{Binding TotalDebtText}" FontSize="16"
                                           FontAttributes="Bold" TextColor="#DC2626"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Crédito total -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#F0FDF4"
                                    Stroke="#BBF7D0" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14,10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Crédito total" FontSize="11" TextColor="#475569"/>
                                    <Label Text="{Binding CreditLimitText}" FontSize="16"
                                           FontAttributes="Bold" TextColor="#15803D"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Balance -->
                            <Border Grid.Column="2"
                                    BackgroundColor="#EFF6FF"
                                    Stroke="#BFDBFE" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14,10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Balance" FontSize="11" TextColor="#475569"/>
                                    <Label Text="{Binding BalanceText}" FontSize="16"
                                           FontAttributes="Bold" TextColor="#2563EB"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- ── Payment info row ── -->
                        <Grid ColumnDefinitions="Auto, *, Auto, *"
                              ColumnSpacing="10" Padding="20,8,20,10">

                            <Label Grid.Column="0" Text="Referencia"
                                   FontSize="12" TextColor="#475569" VerticalOptions="Center"/>
                            <Border Grid.Column="1"
                                    BackgroundColor="White" Stroke="#CBD5E1"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 6"
                                    HeightRequest="36" Padding="10,0">
                                <Entry Text="{Binding Referencia}"
                                       Placeholder="Ref. de pago"
                                       FontSize="12" TextColor="#0F172A"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Label Grid.Column="2" Text="Descripción"
                                   FontSize="12" TextColor="#475569" VerticalOptions="Center"/>
                            <Border Grid.Column="3"
                                    BackgroundColor="White" Stroke="#CBD5E1"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 6"
                                    HeightRequest="36" Padding="10,0">
                                <Entry Text="{Binding Descripcion}"
                                       Placeholder="Descripción del pago"
                                       FontSize="12" TextColor="#0F172A"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#E2E8F0"/>

                        <!-- ── Open entries section title ── -->
                        <Grid ColumnDefinitions="*, Auto, Auto"
                              Padding="20,10,20,6" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="Cuentas por cobrar abiertas"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1E293B"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1"
                                    BackgroundColor="#EFF6FF" Stroke="#BFDBFE"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 6"
                                    Padding="10,4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectAllCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Seleccionar todo" FontSize="11"
                                       FontAttributes="Bold" TextColor="#2563EB"/>
                            </Border>
                            <Border Grid.Column="2"
                                    BackgroundColor="#F1F5F9" Stroke="#CBD5E1"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 6"
                                    Padding="10,4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DeselectAllCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Limpiar" FontSize="11"
                                       FontAttributes="Bold" TextColor="#475569"/>
                            </Border>
                        </Grid>

                        <!-- ── Table header ── -->
                        <Border BackgroundColor="#2563EB"
                                StrokeThickness="0"
                                Margin="14,0"
                                Padding="0">
                            <Grid ColumnDefinitions="80,85,85,90,*,50,95,105,105,115,40"
                                  Padding="6,8" ColumnSpacing="4">
                                <Label Grid.Column="0" Text="Fecha Pub."
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="1" Text="F. Venc."
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="2" Text="Tipo L.M."
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="3" Text="Tipo Doc."
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="4" Text="Descripción"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="5" Text="Store"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="6" Text="Referencia"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"/>
                                <Label Grid.Column="7" Text="Monto"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"
                                       HorizontalTextAlignment="End"/>
                                <Label Grid.Column="8" Text="Balance"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"
                                       HorizontalTextAlignment="End"/>
                                <Label Grid.Column="9" Text="Monto a Aplicar"
                                       FontSize="10" FontAttributes="Bold" TextColor="White"
                                       HorizontalTextAlignment="End"/>
                                <Label Grid.Column="10" Text="✓"
                                       FontSize="11" FontAttributes="Bold" TextColor="White"
                                       HorizontalTextAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ── Table rows ── -->
                        <CollectionView ItemsSource="{Binding OpenEntries}"
                                        Margin="14,0"
                                        MinimumHeightRequest="120"
                                        MaximumHeightRequest="360">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="White"
                                            StrokeThickness="0"
                                            Padding="0">
                                        <Grid ColumnDefinitions="80,85,85,90,*,50,95,105,105,115,40"
                                              Padding="6,4" ColumnSpacing="4">
                                            <BoxView Color="#F1F5F9"
                                                     Grid.ColumnSpan="11"
                                                     Opacity="0.5"
                                                     InputTransparent="True"/>

                                            <Label Grid.Column="0" Text="{Binding PostingDate}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center" LineBreakMode="NoWrap"/>
                                            <Label Grid.Column="1" Text="{Binding DueDate}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center" LineBreakMode="NoWrap"/>
                                            <Label Grid.Column="2" Text="{Binding LedgerTypeName}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="3" Text="{Binding DocumentTypeName}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="4" Text="{Binding Description}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Grid.Column="5" Text="{Binding StoreID}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center"
                                                   HorizontalTextAlignment="Center"/>
                                            <Label Grid.Column="6" Text="{Binding Reference}"
                                                   FontSize="10" TextColor="#334155"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Grid.Column="7" Text="{Binding AmountText}"
                                                   FontSize="10" TextColor="#334155"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="8" Text="{Binding BalanceText}"
                                                   FontSize="10" TextColor="#DC2626"
                                                   FontAttributes="Bold"
                                                   VerticalOptions="Center"
                                                   HorizontalTextAlignment="End"/>

                                            <!-- Monto a Aplicar -->
                                            <Border Grid.Column="9"
                                                    BackgroundColor="White"
                                                    Stroke="#CBD5E1"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 4"
                                                    HeightRequest="28"
                                                    Padding="4,0"
                                                    VerticalOptions="Center">
                                                <Entry Text="{Binding AmountToApplyText}"
                                                       Keyboard="Numeric"
                                                       FontSize="10"
                                                       TextColor="#0F172A"
                                                       BackgroundColor="Transparent"
                                                       VerticalOptions="Center"
                                                       HorizontalTextAlignment="End"/>
                                            </Border>

                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="10"
                                                      IsChecked="{Binding IsSelected}"
                                                      VerticalOptions="Center"
                                                      HorizontalOptions="Center"
                                                      Color="#2563EB"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- ── Totals bar ── -->
                        <Border BackgroundColor="#F8FAFC"
                                Stroke="#E2E8F0" StrokeThickness="1,0,0,0"
                                Margin="14,4,14,8"
                                Padding="12,8"
                                StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="16">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedCountText}"
                                       FontSize="12" TextColor="#475569"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="Total a aplicar:"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#1E293B" VerticalOptions="Center"/>
                                <Label Grid.Column="2"
                                       Text="{Binding TotalToApplyText}"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="#16A34A" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Error / Success (fuera del scroll para que siempre sea visible) -->
                <Border Grid.Row="2" BackgroundColor="#FEF2F2"
                        Stroke="#FCA5A5" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,10" Margin="20,4,20,4"
                        IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#DC2626" HorizontalTextAlignment="Center"/>
                </Border>

                <Border Grid.Row="2" BackgroundColor="#F0FDF4"
                        Stroke="#86EFAC" StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,10" Margin="20,0,20,4"
                        IsVisible="{Binding ShowSuccess}">
                    <Label Text="&#x2705; Abono registrado exitosamente."
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#15803D" HorizontalTextAlignment="Center"/>
                </Border>

                <!-- ══════ Row 3: Footer ══════ -->
                <Border Grid.Row="3"
                        BackgroundColor="#F8FAFC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,14,14"
                        Padding="20,12">
                    <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="10">

                        <!-- Back -->
                        <Border Grid.Column="0"
                                BackgroundColor="White" Stroke="#CBD5E1"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                HeightRequest="40" MinimumWidthRequest="100" Padding="16,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="6"
                                  HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Grid.Column="0" Text="&#x2190;" FontSize="14" TextColor="#475569" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="Volver" FontSize="13" FontAttributes="Bold" TextColor="#475569" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <BoxView Grid.Column="1" Color="Transparent"/>

                        <!-- Close -->
                        <Border Grid.Column="2"
                                BackgroundColor="#EF4444" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="40" MinimumWidthRequest="90" Padding="16,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cerrar" FontSize="13" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <!-- Confirm -->
                        <Border Grid.Column="3"
                                BackgroundColor="#16A34A" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="40" MinimumWidthRequest="160" Padding="16,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ConfirmCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="6"
                                  HorizontalOptions="Center" VerticalOptions="Center">
                                <ActivityIndicator Grid.Column="0"
                                                   IsRunning="{Binding IsBusy}"
                                                   IsVisible="{Binding IsBusy}"
                                                   Color="White" WidthRequest="16" HeightRequest="16"/>
                                <Label Grid.Column="0" Text="&#x1F4B5;" FontSize="14" VerticalOptions="Center"
                                       IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                                <Label Grid.Column="1" Text="Aplicar Abono"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ══════ Payment Type Dialog (overlay) ══════ -->
        <Grid IsVisible="{Binding ShowPaymentTypeDialog}"
              InputTransparent="False"
              ZIndex="10">
            <BoxView Color="#000000" Opacity="0.5"/>
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    MaximumWidthRequest="420"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="0"
                    Shadow="{x:Null}">
                <VerticalStackLayout Spacing="0">

                    <!-- Dialog header -->
                    <Border BackgroundColor="#1E293B" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14,14,0,0"
                            Padding="20,14">
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="&#x1F4B3;" FontSize="18" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="¿Cómo desea aplicar el pago?"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding ShowPaymentOptions}"/>
                            <Label Grid.Column="1" Text="Pago Parcial"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding ShowPartialInput}"/>
                        </Grid>
                    </Border>

                    <!-- Entry info -->
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0" Padding="16,12">
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding PendingEntryReference}"
                                   FontSize="13" FontAttributes="Bold" TextColor="#334155"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding PendingEntryBalanceText}"
                                   FontSize="16" FontAttributes="Bold" TextColor="#DC2626"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <BoxView HeightRequest="1" Color="#E2E8F0"/>

                    <!-- ═══ STEP 1: Payment type options ═══ -->
                    <VerticalStackLayout Spacing="10" Padding="20,16"
                                         IsVisible="{Binding ShowPaymentOptions}">

                        <!-- Pago Total -->
                        <Border BackgroundColor="#F0FDF4" Stroke="#86EFAC"
                                StrokeThickness="1.5" StrokeShape="RoundRectangle 10"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PayTotalCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#16A34A" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8" WidthRequest="40" HeightRequest="40">
                                    <Label Text="&#x2705;" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Pago Total" FontSize="14" FontAttributes="Bold"
                                           TextColor="#15803D"/>
                                    <Label Text="Aplicar el monto total del balance" FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Pago Parcial -->
                        <Border BackgroundColor="#EFF6FF" Stroke="#93C5FD"
                                StrokeThickness="1.5" StrokeShape="RoundRectangle 10"
                                Padding="14,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PayPartialCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#2563EB" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8" WidthRequest="40" HeightRequest="40">
                                    <Label Text="&#x270F;" FontSize="18" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Pago Parcial" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1D4ED8"/>
                                    <Label Text="Ingresar el monto manualmente" FontSize="11"
                                           TextColor="#64748B"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <!-- ═══ STEP 2: Partial amount input ═══ -->
                    <VerticalStackLayout Spacing="12" Padding="20,16"
                                         IsVisible="{Binding ShowPartialInput}">

                        <!-- Balance total de la factura -->
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Balance de la factura:"
                                   FontSize="13" TextColor="#475569" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding PendingEntryBalanceText}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#1E293B"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Monto a pagar input -->
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Monto a pagar:" FontSize="12" FontAttributes="Bold"
                                   TextColor="#334155"/>
                            <Border BackgroundColor="White" Stroke="#93C5FD"
                                    StrokeThickness="2" StrokeShape="RoundRectangle 8"
                                    HeightRequest="44" Padding="12,0">
                                <Entry Text="{Binding PartialAmountText}"
                                       Keyboard="Numeric" FontSize="16"
                                       FontAttributes="Bold" TextColor="#0F172A"
                                       BackgroundColor="Transparent"
                                       Placeholder="0.00"
                                       PlaceholderColor="#94A3B8"
                                       HorizontalTextAlignment="End"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Remaining balance -->
                        <Border BackgroundColor="#FEF2F2" Stroke="#FECACA"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                Padding="12,10">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Restante por pagar:"
                                       FontSize="13" TextColor="#DC2626" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding RemainingBalanceText}"
                                       FontSize="16" FontAttributes="Bold" TextColor="#DC2626"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Buttons row -->
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Margin="0,4,0,0">
                            <!-- Back -->
                            <Border Grid.Column="0" BackgroundColor="#F1F5F9" Stroke="#CBD5E1"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                    HeightRequest="38" Padding="14,0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BackToPaymentOptionsCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="&#x2190; Volver" FontSize="12" FontAttributes="Bold"
                                       TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <!-- Confirm partial -->
                            <Border Grid.Column="2" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    HeightRequest="38" Padding="14,0"
                                    BackgroundColor="#2563EB">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ConfirmPartialCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Aplicar Monto" FontSize="12" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>

                    <!-- Cancel -->
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0"
                            StrokeShape="RoundRectangle 0,0,14,14"
                            Padding="16,10">
                        <Label Text="Cancelar" FontSize="12" TextColor="#64748B"
                               FontAttributes="Bold" HorizontalTextAlignment="Center"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelPaymentDialogCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══════ Confirm Payment Dialog (overlay) ══════ -->
        <Grid IsVisible="{Binding ShowConfirmDialog}"
              InputTransparent="False"
              ZIndex="20">
            <BoxView Color="#000000" Opacity="0.55"/>
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    MaximumWidthRequest="480"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Padding="0"
                    Shadow="{x:Null}">
                <VerticalStackLayout Spacing="0">

                    <!-- Header -->
                    <Border BackgroundColor="#1E293B" StrokeThickness="0"
                            StrokeShape="RoundRectangle 14,14,0,0"
                            Padding="20,14">
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="&#x1F9FE;" FontSize="18" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Confirmar Abono"
                                   FontSize="16" FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Summary -->
                    <Border BackgroundColor="#F8FAFC" StrokeThickness="0" Padding="20,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding CustomerName, StringFormat='Cliente: {0}'}"
                                   FontSize="12" TextColor="#475569"/>
                            <Label Text="{Binding ConfirmSummaryText}"
                                   FontSize="14" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Label Text="{Binding TotalToApplyText, StringFormat='Monto total: {0}'}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#16A34A"/>
                        </VerticalStackLayout>
                    </Border>

                    <BoxView HeightRequest="1" Color="#E2E8F0"/>

                    <!-- Tender selection -->
                    <VerticalStackLayout Spacing="8" Padding="20,14">
                        <Label Text="Seleccione el método de pago:" FontSize="13"
                               FontAttributes="Bold" TextColor="#1E293B"/>

                        <FlexLayout Wrap="Wrap" JustifyContent="Start"
                                    BindableLayout.ItemsSource="{Binding PaymentTenders}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8" Padding="14,10"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="2"
                                            BackgroundColor="White" Stroke="#CBD5E1">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectConfirmTenderCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding DisplayText}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="#334155" VerticalOptions="Center"/>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <Label Text="{Binding SelectedTenderText, StringFormat='▶ {0}'}"
                               FontSize="12" TextColor="#2563EB" FontAttributes="Bold"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E2E8F0"/>

                    <!-- Info: what will be created -->
                    <Border BackgroundColor="#EFF6FF" StrokeThickness="0" Padding="20,12">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Se creará:" FontSize="11" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Label Text="• Registro de pago (AR_LedgerEntry)" FontSize="10" TextColor="#475569"/>
                            <Label Text="• Aplicación por cada factura seleccionada" FontSize="10" TextColor="#475569"/>
                            <Label Text="• Actualización de balances" FontSize="10" TextColor="#475569"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error message -->
                    <Border BackgroundColor="#FEF2F2"
                            Stroke="#FCA5A5" StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="10,8" Margin="20,8,20,0"
                            IsVisible="{Binding HasError}">
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#DC2626" HorizontalTextAlignment="Center"/>
                    </Border>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*, 10, *" Padding="20,14">
                        <Border Grid.Column="0" BackgroundColor="#F1F5F9" Stroke="#CBD5E1"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                HeightRequest="42" Padding="12,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelConfirmDialogCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cancelar" FontSize="13" FontAttributes="Bold"
                                   TextColor="#475569" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="#16A34A" StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="42" Padding="12,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding FinalConfirmCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="6"
                                  HorizontalOptions="Center" VerticalOptions="Center">
                                <ActivityIndicator Grid.Column="0"
                                                   IsRunning="{Binding IsBusy}"
                                                   IsVisible="{Binding IsBusy}"
                                                   Color="White" WidthRequest="16" HeightRequest="16"/>
                                <Label Grid.Column="0" Text="&#x1F4B5;" FontSize="14" VerticalOptions="Center"
                                       IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"/>
                                <Label Grid.Column="1" Text="Confirmar Pago"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentView>
