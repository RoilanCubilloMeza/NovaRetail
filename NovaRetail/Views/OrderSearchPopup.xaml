<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.OrderSearchPopup">

    <Grid BackgroundColor="#80000000">
        <Border StrokeShape="RoundRectangle 16"
                Stroke="#E5E7EB"
                BackgroundColor="White"
                MaximumWidthRequest="640"
                MaximumHeightRequest="580"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="24">

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="14">

                <!-- Titulo -->
                <Label Grid.Row="0"
                       Text="{Binding TitleText}"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="#111827"/>

                <!-- Barra de busqueda -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Buscar por # orden, cliente o cajero..."
                           Text="{Binding SearchText}"
                           ReturnCommand="{Binding SearchCommand}"
                           FontSize="13"
                           BackgroundColor="#F9FAFB"
                           HeightRequest="40"/>
                        <Button Grid.Column="1"
                            Text="Buscar"
                            Command="{Binding SearchCommand}"
                            FontSize="12"
                            BackgroundColor="#3B82F6"
                            TextColor="White"
                            HeightRequest="40"
                            CornerRadius="8"
                            Padding="16,0"/>
                    <Grid Grid.Column="2"
                          WidthRequest="44"
                          HeightRequest="40">
                        <Button Text="&#x21BB;"
                                Command="{Binding RefreshCommand}"
                                FontSize="18"
                                BackgroundColor="#E5E7EB"
                                TextColor="#111827"
                                HeightRequest="40"
                                WidthRequest="44"
                                CornerRadius="8"
                                Padding="0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding IsBusy}"
                                             Value="True">
                                    <Setter Property="IsVisible"
                                            Value="False"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Border IsVisible="False"
                                BackgroundColor="#E5E7EB"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                HeightRequest="40"
                                WidthRequest="44"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsBusy}"
                                             Value="True">
                                    <Setter Property="IsVisible"
                                            Value="True"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                               IsVisible="{Binding IsBusy}"
                                               Color="#111827"
                                               HeightRequest="22"
                                               WidthRequest="22"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Grid>

                      <Label Grid.Row="2"
                          Text="{Binding LastRefreshText}"
                          IsVisible="{Binding HasLastRefreshText}"
                          FontSize="11"
                          TextColor="#6B7280"/>

                <!-- Lista de resultados -->
                      <CollectionView Grid.Row="3"
                                ItemsSource="{Binding Orders}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="{Binding StatusMessage}"
                               FontSize="13"
                               TextColor="#9CA3AF"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"
                               Margin="0,30"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="#E5E7EB"
                                    BackgroundColor="#F9FAFB"
                                    Padding="12,10"
                                    Margin="0,3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.SelectCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="2">

                                    <!-- Titulo + Total -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding DisplayTitle}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="#111827"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DisplayTotal}"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="#059669"
                                           HorizontalTextAlignment="End"/>

                                    <!-- Fecha + Articulos + Cajero -->
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           FontSize="11"
                                           TextColor="#6B7280">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="&#x1F4C5; "/>
                                                <Span Text="{Binding DisplayDate}"/>
                                                <Span Text="  |  "/>
                                                <Span Text="{Binding DisplayItems}"/>
                                                <Span Text="  |  "/>
                                                <Span Text="&#x1F464; "/>
                                                <Span Text="{Binding DisplayCashier}" FontAttributes="Bold"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- Cliente (solo si tiene) -->
                                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                           IsVisible="{Binding HasClientRef}"
                                           FontSize="11"
                                           TextColor="#3B82F6">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="&#x1F9D1;&#x200D;&#x1F4BC; "/>
                                                <Span Text="{Binding DisplayClient}" FontAttributes="Italic"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                            Text="Cancelar cotización"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.CancelOrderCommand}"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding CanCancel}"
                                            FontSize="12"
                                            BackgroundColor="#FEF2F2"
                                            TextColor="#B91C1C"
                                            BorderColor="#FCA5A5"
                                            BorderWidth="1"
                                            CornerRadius="8"
                                            HorizontalOptions="Start"
                                            Padding="12,6"
                                            Margin="0,8,0,0"/>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ActivityIndicator -->
                <Grid Grid.Row="3"
                      IsVisible="{Binding IsBusy}"
                      BackgroundColor="#66FFFFFF">
                    <Border BackgroundColor="White"
                            Stroke="#BFDBFE"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="20,16"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <VerticalStackLayout Spacing="10">
                            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                               IsVisible="{Binding IsBusy}"
                                               Color="#2563EB"
                                               HeightRequest="34"
                                               WidthRequest="34"
                                               HorizontalOptions="Center"/>
                            <Label Text="Actualizando órdenes..."
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#1F2937"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Boton Cerrar -->
                <Button Grid.Row="4"
                        Text="Cerrar"
                        Command="{Binding CloseCommand}"
                        FontSize="13"
                        BackgroundColor="#F3F4F6"
                        TextColor="#374151"
                        HeightRequest="40"
                        CornerRadius="8"
                        HorizontalOptions="Fill"/>
            </Grid>
        </Border>
    </Grid>

</ContentView>