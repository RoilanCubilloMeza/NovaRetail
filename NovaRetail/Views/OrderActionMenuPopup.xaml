<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.OrderActionMenuPopup">

    <Grid BackgroundColor="#80000000">
        <Border BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                MaximumWidthRequest="460"
                Margin="20"
                Padding="0"
                HorizontalOptions="Center"
                VerticalOptions="Center">

            <Grid RowDefinitions="Auto,Auto" RowSpacing="0">
                <Border Grid.Row="0"
                        BackgroundColor="{Binding AccentColor}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16,16,0,0"
                        Padding="20,16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding TitleText}"
                                   FontSize="19"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                            <Label Text="{Binding SubtitleText}"
                                   FontSize="12"
                                   TextColor="#E5E7EB"/>
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="x"
                                Command="{Binding CloseCommand}"
                                BackgroundColor="#33FFFFFF"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                WidthRequest="34"
                                HeightRequest="34"
                                CornerRadius="17"
                                Padding="0"/>
                    </Grid>
                </Border>

                <VerticalStackLayout Grid.Row="1"
                                     Padding="22,22,22,18"
                                     Spacing="12">
                    <Button Text="{Binding PrimaryText}"
                            Command="{Binding PrimaryCommand}"
                            BackgroundColor="{Binding AccentColor}"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="48"
                            CornerRadius="10"
                            Padding="16,0"/>

                    <Border BackgroundColor="{Binding SoftColor}"
                            Stroke="{Binding StrokeColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            HeightRequest="48"
                            Padding="14,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SecondaryCommand}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="{Binding SecondaryIcon}"
                                   FontSize="18"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding SecondaryText}"
                                   TextColor="{Binding LabelColor}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2"
                                   Text="&#x276F;"
                                   TextColor="{Binding LabelColor}"
                                   FontSize="13"
                                   Opacity="0.6"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Button Text="Cancelar"
                            Command="{Binding CloseCommand}"
                            BackgroundColor="#F3F4F6"
                            TextColor="#374151"
                            FontSize="13"
                            FontAttributes="Bold"
                            HeightRequest="42"
                            CornerRadius="10"
                            Margin="0,4,0,0"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentView>
