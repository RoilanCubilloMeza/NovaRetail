<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:NovaRetail.Controls"
             xmlns:viewModels="clr-namespace:NovaRetail.ViewModels"
             x:Class="NovaRetail.Views.ProductsPanel"
             x:Name="ThisPanel">

    <Grid>

        <Border Style="{DynamicResource PanelCollapseSliver}"
                Margin="6,10,6,10"
                IsVisible="False">
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding IsProductsPanelVisible}" Value="False">
                    <Setter Property="IsVisible" Value="True"/>
                </DataTrigger>
            </Border.Triggers>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleProductsPanelCommand}"/>
            </Border.GestureRecognizers>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                <Label Text="&#x1F4E6;" FontSize="18" TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="&#x25B6;" FontSize="16" TextColor="White"
                       HorizontalTextAlignment="Center" Opacity="0.7"/>
            </VerticalStackLayout>
        </Border>

        <Border Style="{DynamicResource PanelCard}"
                Margin="6,10,6,10"
                IsVisible="{Binding IsProductsPanelVisible}">

            <Grid RowDefinitions="Auto, *" RowSpacing="0">

                <Border Grid.Row="0" Style="{DynamicResource PanelHeaderBar}">
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#x1F4E6;"
                               FontSize="14"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label Text="Productos"
                                   TextColor="White"
                                   FontSize="13"
                                   FontAttributes="Bold"/>
                            <Label Text="Lista rápida para venta"
                                   FontSize="10"
                                   TextColor="#CBD5E1"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="#475569"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="8,2"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"
                                IsVisible="{Binding HasProductCount}">
                            <Label Text="{Binding ProductCountText}"
                                   FontSize="10"
                                   TextColor="#E2E8F0"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border Grid.Column="3"
                                BackgroundColor="#475569"
                                StrokeShape="RoundRectangle 5"
                                StrokeThickness="0"
                                WidthRequest="28"
                                HeightRequest="28"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleProductsPanelCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="&#x25C0;"
                                   FontSize="11"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto, Auto, Auto, *, Auto, Auto"
                      RowSpacing="0"
                      Padding="10,8,10,10">

                    <Border Grid.Row="0" Style="{DynamicResource InputBox}" Margin="0,2,0,8">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0"
                                   Text="&#x1F50D;&#xFE0E;"
                                   FontSize="15"
                                   TextColor="{DynamicResource Gray400}"
                                   VerticalOptions="Center"
                                   Margin="0,0,6,0"/>
                            <Entry Grid.Column="1"
                                   Placeholder="Buscar o escanear producto..."
                                   Text="{Binding ProductSearchText, Mode=TwoWay}"
                                   ReturnCommand="{Binding SearchProductCommand}"
                                   FontSize="13"
                                   BackgroundColor="Transparent"/>
                        </Grid>
                    </Border>

                    <ScrollView Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Margin="0,0,0,8">
                        <HorizontalStackLayout Spacing="6"
                                               BindableLayout.ItemsSource="{Binding CategoryTabs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ProductCatalogViewModel+CategoryTabItem">
                                    <controls:CategoryTab Text="{Binding Text}"
                                                          IsActive="{Binding IsActive}"
                                                          Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.SelectCategoryCommand}"
                                                          CommandParameter="{Binding Key}"/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Border Grid.Row="2"
                            BackgroundColor="#F8FAFC"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,8"
                            Margin="0,0,0,6"
                            IsVisible="{Binding IsProductListView}">
                        <Grid ColumnDefinitions="1.25*, 1.05*, 2.7*, 1.1*, Auto"
                              ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Código"
                                   Style="{DynamicResource TableHeaderLabel}"/>
                            <Label Grid.Column="1"
                                   Text="Precio"
                                   Style="{DynamicResource TableHeaderLabel}"/>
                            <Label Grid.Column="2"
                                   Text="Producto"
                                   Style="{DynamicResource TableHeaderLabel}"/>
                            <Label Grid.Column="3"
                                   Text="Disponibilidad"
                                   Style="{DynamicResource TableHeaderLabel}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="4"
                                   Text="Acción"
                                   Style="{DynamicResource TableHeaderLabel}"
                                   HorizontalTextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <CollectionView x:Name="ProductsListCollectionView"
                                        ItemsSource="{Binding Products}"
                                        ItemSizingStrategy="MeasureAllItems"
                                        SelectionMode="None"
                                        RemainingItemsThreshold="8"
                                        Scrolled="ProductsCollectionView_Scrolled"
                                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreProductsCommand}"
                                        IsVisible="{Binding IsProductListView}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="White"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="10,8">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding HasCartQuantity}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#F0FDF4"/>
                                                <Setter Property="Stroke" Value="#86EFAC"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                                  CommandParameter="{Binding .}"/>
                                            <TapGestureRecognizer Buttons="Secondary"
                                                                  Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                                  CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="1.25*, 1.05*, 2.7*, 1.1*, Auto"
                                              ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0"
                                                                 Spacing="1"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Code}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource Gray900}"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding CartQuantityText}"
                                                       FontSize="9"
                                                       TextColor="#2563EB"
                                                       LineBreakMode="TailTruncation"
                                                       IsVisible="{Binding HasCartQuantity}"/>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="1"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding PriceColonesText}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{DynamicResource Gray900}"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding Price}"
                                                       FontSize="10"
                                                       TextColor="#64748B"
                                                       LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource Gray900}"
                                                   VerticalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>

                                            <Border Grid.Column="3"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    Padding="8,4"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsNonInventory}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsOutOfStock}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsLowStock}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsOutOfStock}" Value="False">
                                                        <Setter Property="BackgroundColor" Value="#ECFDF5"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding StockDisplayText}"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsNonInventory}" Value="True">
                                                            <Setter Property="TextColor" Value="#1D4ED8"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsOutOfStock}" Value="True">
                                                            <Setter Property="TextColor" Value="#B91C1C"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="TextColor" Value="#B45309"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsOutOfStock}" Value="False">
                                                            <Setter Property="TextColor" Value="#047857"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>

                                            <Grid Grid.Column="4"
                                                  ColumnDefinitions="Auto, Auto"
                                                  ColumnSpacing="6"
                                                  VerticalOptions="Center">
                                                <Border Grid.Column="0"
                                                        BackgroundColor="#F97316"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 8"
                                                        HeightRequest="30"
                                                        WidthRequest="30"
                                                        IsVisible="{Binding HasCartQuantity}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                                              CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="-"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>
                                                </Border>

                                                <Border Grid.Column="1"
                                                        BackgroundColor="#22C55E"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 8"
                                                        HeightRequest="30"
                                                        WidthRequest="30">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                                              CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="+"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="No hay productos para mostrar"
                                       Style="{DynamicResource EmptyCollectionLabel}"/>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <CollectionView x:Name="ProductsCardsCollectionView"
                                        ItemsSource="{Binding Source={x:Reference ThisPanel}, Path=CardRows}"
                                        ItemSizingStrategy="MeasureFirstItem"
                                        SelectionMode="None"
                                        RemainingItemsThreshold="8"
                                        Scrolled="ProductsCollectionView_Scrolled"
                                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreProductsCommand}"
                                        IsVisible="{Binding IsProductCardView}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="12">
                                        <controls:ProductCard WidthRequest="{Binding Source={x:Reference ThisPanel}, Path=CardItemWidth}"
                                                              Emoji="{Binding Product1.Emoji}"
                                                              ProductName="{Binding Product1.Name}"
                                                              Code="{Binding Product1.Code}"
                                                              Price="{Binding Product1.Price}"
                                                              PriceColones="{Binding Product1.PriceColonesText}"
                                                              OldPrice="{Binding Product1.OldPrice}"
                                                              Stock="{Binding Product1.Stock}"
                                                              IsNonInventory="{Binding Product1.IsNonInventory}"
                                                              Quantity="{Binding Product1.CartQuantity}"
                                                              Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                              CommandParameter="{Binding Product1}"
                                                              DecrementCommand="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                              DecrementCommandParameter="{Binding Product1}"/>

                                        <controls:ProductCard WidthRequest="{Binding Source={x:Reference ThisPanel}, Path=CardItemWidth}"
                                                              IsVisible="{Binding HasProduct2}"
                                                              Emoji="{Binding Product2.Emoji}"
                                                              ProductName="{Binding Product2.Name}"
                                                              Code="{Binding Product2.Code}"
                                                              Price="{Binding Product2.Price}"
                                                              PriceColones="{Binding Product2.PriceColonesText}"
                                                              OldPrice="{Binding Product2.OldPrice}"
                                                              Stock="{Binding Product2.Stock}"
                                                              IsNonInventory="{Binding Product2.IsNonInventory}"
                                                              Quantity="{Binding Product2.CartQuantity}"
                                                              Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                              CommandParameter="{Binding Product2}"
                                                              DecrementCommand="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                              DecrementCommandParameter="{Binding Product2}"/>

                                        <controls:ProductCard WidthRequest="{Binding Source={x:Reference ThisPanel}, Path=CardItemWidth}"
                                                              IsVisible="{Binding HasProduct3}"
                                                              Emoji="{Binding Product3.Emoji}"
                                                              ProductName="{Binding Product3.Name}"
                                                              Code="{Binding Product3.Code}"
                                                              Price="{Binding Product3.Price}"
                                                              PriceColones="{Binding Product3.PriceColonesText}"
                                                              OldPrice="{Binding Product3.OldPrice}"
                                                              Stock="{Binding Product3.Stock}"
                                                              IsNonInventory="{Binding Product3.IsNonInventory}"
                                                              Quantity="{Binding Product3.CartQuantity}"
                                                              Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                              CommandParameter="{Binding Product3}"
                                                              DecrementCommand="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                              DecrementCommandParameter="{Binding Product3}"/>

                                        <controls:ProductCard WidthRequest="{Binding Source={x:Reference ThisPanel}, Path=CardItemWidth}"
                                                              IsVisible="{Binding HasProduct4}"
                                                              Emoji="{Binding Product4.Emoji}"
                                                              ProductName="{Binding Product4.Name}"
                                                              Code="{Binding Product4.Code}"
                                                              Price="{Binding Product4.Price}"
                                                              PriceColones="{Binding Product4.PriceColonesText}"
                                                              OldPrice="{Binding Product4.OldPrice}"
                                                              Stock="{Binding Product4.Stock}"
                                                              IsNonInventory="{Binding Product4.IsNonInventory}"
                                                              Quantity="{Binding Product4.CartQuantity}"
                                                              Command="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.AddProductCommand}"
                                                              CommandParameter="{Binding Product4}"
                                                              DecrementCommand="{Binding Source={x:Reference ThisPanel}, Path=BindingContext.DecrementProductCommand}"
                                                              DecrementCommandParameter="{Binding Product4}"/>
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="No hay productos para mostrar"
                                       Style="{DynamicResource EmptyCollectionLabel}"/>
                            </CollectionView.EmptyView>
                        </CollectionView>

                        <Border BackgroundColor="#CCFFFFFF"
                                StrokeThickness="0"
                                IsVisible="{Binding IsSearchingProducts}"
                                InputTransparent="False">
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="10">
                                <ActivityIndicator IsRunning="{Binding IsSearchingProducts}"
                                                   Color="{DynamicResource AccentBlue}"
                                                   WidthRequest="36"
                                                   HeightRequest="36"/>
                                <Label Text="{Binding LoadingMessageText}"
                                       FontSize="13"
                                       TextColor="{DynamicResource Gray600}"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Grid.Row="4" Spacing="6" Margin="0,8,0,0">
                        <Border BackgroundColor="#F8FAFC"
                                Stroke="#E2E8F0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,8"
                                HorizontalOptions="Center"
                                IsVisible="{Binding IsLoadingMoreProducts}">
                            <HorizontalStackLayout Spacing="8"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center">
                                <ActivityIndicator IsRunning="{Binding IsLoadingMoreProducts}"
                                                   Color="#22C55E"
                                                   WidthRequest="20"
                                                   HeightRequest="20"
                                                   VerticalOptions="Center"/>
                                <Label Text="{Binding LoadingMessageText}"
                                       FontSize="12"
                                       TextColor="{DynamicResource Gray600}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border BackgroundColor="{DynamicResource AccentBlue}"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="14,10"
                                HorizontalOptions="Center"
                                IsVisible="{Binding CanLoadMore}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LoadMoreProductsCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="&#x1F4E6;"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="Cargar más productos"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <VerticalStackLayout Spacing="4"
                                             IsVisible="{Binding HasProductCount}"
                                             Padding="10,0">
                            <ProgressBar Progress="{Binding LoadProgress}"
                                         ProgressColor="{DynamicResource AccentGreen}"
                                         HeightRequest="4"/>
                            <Label Text="{Binding ProductCountText}"
                                   FontSize="11"
                                   TextColor="{DynamicResource Gray400}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Grid Grid.Row="5"
                          ColumnDefinitions="Auto, *"
                          ColumnSpacing="8"
                          Margin="0,8,0,0">
                        <Border Grid.Column="0"
                                BackgroundColor="#DBEAFE"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                Padding="14,0"
                                MinimumWidthRequest="140">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ApplyManualExonerationCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Spacing="6">
                                <Label Text="%"
                                       FontSize="16"
                                       TextColor="#1D4ED8"
                                       VerticalOptions="Center"/>
                                <Label Text="Exonerar"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#1D4ED8"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="1" Style="{DynamicResource PrimaryActionBorder}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding InvoiceCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   Spacing="8">
                                <Label Text="&#x2611;"
                                       FontSize="18"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                                <Label Text="Cobrar"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</ContentView>
