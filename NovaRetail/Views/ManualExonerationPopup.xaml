<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.ManualExonerationPopup">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                Stroke="#CBD5E1"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                WidthRequest="500"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Padding="0">

            <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="0">

                <!-- Título -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E3A5F"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10,10,0,0"
                        Padding="20,14">
                    <Label Text="Información requerida para la exoneración"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <!-- Formulario -->
                <VerticalStackLayout Grid.Row="1" Padding="20,16,20,0" Spacing="12">

                    <!-- Número + Buscar -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Número"
                               FontSize="13" FontAttributes="Bold" TextColor="#1E293B"
                               VerticalOptions="Center" MinimumWidthRequest="70"/>
                        <Border Grid.Column="1"
                                Stroke="#CBD5E1" StrokeThickness="1"
                                StrokeShape="RoundRectangle 4"
                                Padding="8,4" HeightRequest="36">
                            <Entry Text="{Binding AuthorizationNumber, Mode=TwoWay}"
                                   FontSize="13" BackgroundColor="Transparent"
                                   Placeholder="Ej. AL-00020402-24"
                                   ReturnCommand="{Binding BuscarCommand}"/>
                        </Border>
                        <Border Grid.Column="2"
                                BackgroundColor="#3B82F6"
                                StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                Padding="14,8" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BuscarCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Buscar" FontSize="13" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Tipo Documento -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Tipo Documento"
                               FontSize="13" FontAttributes="Bold" TextColor="#1E293B"/>
                        <Border Stroke="#CBD5E1" StrokeThickness="1"
                                StrokeShape="RoundRectangle 4"
                                Padding="4,0" HeightRequest="38">
                            <Picker ItemsSource="{Binding DocumentTypes}"
                                    SelectedItem="{Binding SelectedDocumentType, Mode=TwoWay}"
                                    ItemDisplayBinding="{Binding Descripcion}"
                                    FontSize="13" BackgroundColor="Transparent"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Fecha Emisión | Institución -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Fecha Emisión"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Border Stroke="#CBD5E1" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4,0" HeightRequest="38">
                                <DatePicker Date="{Binding FechaEmision, Mode=TwoWay}"
                                            Format="d/M/yyyy" FontSize="13"
                                            BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Institución"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Border Stroke="#CBD5E1" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="8,4" HeightRequest="38">
                                <Entry Text="{Binding Institucion, Mode=TwoWay}"
                                       FontSize="13" BackgroundColor="Transparent"
                                       TextColor="#F97316"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Fecha Vencimiento | Monto Exonerado -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Fecha Vencimiento"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Border Stroke="#CBD5E1" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 4"
                                    Padding="4,0" HeightRequest="38">
                                <DatePicker Date="{Binding FechaVencimiento, Mode=TwoWay}"
                                            Format="d/M/yyyy" FontSize="13"
                                            BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Monto Exonerado"
                                   FontSize="13" FontAttributes="Bold" TextColor="#1E293B"/>
                            <Label Text="{Binding MontoExoneradoText}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#1D4ED8"
                                   VerticalOptions="Center" Margin="4,8,0,0"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- % Compra Exonerado + Exonerar -->
                    <Grid ColumnDefinitions="Auto,140,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="% Compra Exonerado"
                               FontSize="13" FontAttributes="Bold" TextColor="#1E293B"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                Stroke="#CBD5E1" StrokeThickness="1"
                                StrokeShape="RoundRectangle 4"
                                Padding="8,4" HeightRequest="36">
                            <Entry Text="{Binding PorcentajeText, Mode=TwoWay}"
                                   Keyboard="Numeric" FontSize="13"
                                   BackgroundColor="Transparent"/>
                        </Border>
                        <Border Grid.Column="2"
                                BackgroundColor="#22C55E"
                                StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                Padding="14,8" HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CalcularMontoCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Exonerar" FontSize="13" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                </VerticalStackLayout>

                <!-- Mensaje de estado -->
                <Label Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       FontSize="11" TextColor="#EF4444"
                       Margin="20,8,20,0">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsStatusSuccess}" Value="True">
                            <Setter Property="TextColor" Value="#16A34A"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Botones -->
                <Border Grid.Row="3"
                        BackgroundColor="#F8FAFC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,10,10"
                        Padding="20,12,20,14"
                        Margin="0,8,0,0">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">

                        <ActivityIndicator Grid.Column="0"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="#3B82F6"
                                           WidthRequest="22" HeightRequest="22"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center"/>

                        <!-- Aplicar -->
                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                Padding="24,10" HeightRequest="40">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#94A3B8"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsBusy}" Value="False">
                                    <Setter Property="BackgroundColor" Value="#22C55E"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ApplyCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Aplicar" FontSize="14" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </Border>

                        <!-- Cancelar -->
                        <Border Grid.Column="3"
                                BackgroundColor="#E2E8F0"
                                StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                Padding="20,10" HeightRequest="40">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cancelar" FontSize="14" FontAttributes="Bold"
                                   TextColor="#475569" VerticalOptions="Center"/>
                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>

</ContentView>
