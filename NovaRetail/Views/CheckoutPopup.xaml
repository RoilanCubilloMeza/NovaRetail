<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CheckoutPopup"
             x:Name="Root">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                MaximumWidthRequest="480"
                Margin="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Shadow="{x:Null}">

            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="0">

                <!-- Title bar -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14,14,0,0"
                        Padding="18,12">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="&#x2705;" FontSize="16"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Confirmar Cobro"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Revise el total y la forma de pago antes de confirmar."
                                   FontSize="11"
                                   TextColor="#CBD5E1"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollView Grid.Row="1"
                            InputTransparent="{Binding IsSubmitting}">
                    <VerticalStackLayout Spacing="0" Padding="18,16,18,8">

                        <!-- Resumen de totales -->
                        <Border BackgroundColor="#F8FAFC"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#E2E8F0"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Subtotal"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding SubtotalText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasDiscount}">
                                    <Label Grid.Column="0" Text="Descuentos"
                                           FontSize="13" TextColor="#EF4444" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding DiscountText}"
                                           FontSize="13" TextColor="#EF4444" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding TaxSystemText}"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,4"/>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="TOTAL"
                                           FontSize="17" FontAttributes="Bold"
                                           TextColor="#1E293B" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                        <Label Text="{Binding TotalText}"
                                               FontSize="22" FontAttributes="Bold"
                                               TextColor="#1E293B" HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding TotalColonesText}"
                                               FontSize="12" TextColor="#64748B"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        <!-- IVA + Cotización pills -->
                        <Grid ColumnDefinitions="*, 8, *" Margin="0,0,0,16">
                            <Border Grid.Column="0" BackgroundColor="#F0FDF4"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="IVA" FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxSystemText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#065F46"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#EFF6FF"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="Cotiz." FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding QuoteDaysText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Vendedor -->
                        <Border Padding="14,10"
                                Margin="0,0,0,14"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding HasSalesRep}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#FEF3C7"/>
                                    <Setter Property="Stroke" Value="#F59E0B"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding HasSalesRep}" Value="False">
                                    <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                    <Setter Property="Stroke" Value="#E2E8F0"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="&#x1F9D1;" FontSize="14"
                                       VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="Vendedor"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="#6B7280"/>
                                    <Label Text="{Binding SalesRepText}"
                                           FontSize="13" FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding HasSalesRep}" Value="True">
                                                <Setter Property="TextColor" Value="#92400E"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding HasSalesRep}" Value="False">
                                                <Setter Property="TextColor" Value="#94A3B8"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>
                                <Border Grid.Column="2"
                                        BackgroundColor="#D97706"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,6"
                                        VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ChangeSalesRepCommand}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding SalesRepButtonText}"
                                           FontSize="12" FontAttributes="Bold"
                                           TextColor="White"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#EEF2FF"
                                Stroke="#C7D2FE"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,10"
                                Margin="0,0,0,16">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Cobro"
                                       FontSize="11"
                                       TextColor="#6366F1"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding SelectedTenderText}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#1E1B4B"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Credit info preview (visible only when paying with credit) -->
                        <Border BackgroundColor="#F0FDF4"
                                Stroke="#86EFAC"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,12"
                                Margin="0,0,0,16"
                                IsVisible="{Binding ShowCreditPreview}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="💳 Información de Crédito"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#166534"/>
                                <Label Text="{Binding CreditClientName}"
                                       FontSize="12"
                                       TextColor="#15803D"/>
                                <BoxView HeightRequest="1" Color="#BBF7D0" Margin="0,2"/>
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4" ColumnSpacing="4">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Límite de crédito"
                                           FontSize="12" TextColor="#4B5563"/>
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding CreditLimitText}"
                                           FontSize="12" FontAttributes="Bold" TextColor="#1F2937"
                                           HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="Saldo actual"
                                           FontSize="12" TextColor="#4B5563"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding CreditBalanceText}"
                                           FontSize="12" FontAttributes="Bold" TextColor="#1F2937"
                                           HorizontalTextAlignment="End"/>
                                    <Label Grid.Row="2" Grid.Column="0" Text="Disponible actual"
                                           FontSize="12" TextColor="#4B5563"/>
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding CreditAvailableText}"
                                           FontSize="12" FontAttributes="Bold" TextColor="#166534"
                                           HorizontalTextAlignment="End"/>
                                    <BoxView Grid.Row="3" Grid.ColumnSpan="2" HeightRequest="1" Color="#BBF7D0"/>
                                    <Label Grid.Row="4" Grid.Column="0" Text="Disponible después de venta"
                                           FontSize="12" FontAttributes="Bold" TextColor="#4B5563"/>
                                    <Label Grid.Row="4" Grid.Column="1" Text="{Binding CreditAfterSaleText}"
                                           FontSize="12" FontAttributes="Bold"
                                           TextColor="#1F2937"
                                           HorizontalTextAlignment="End"/>
                                </Grid>
                                <Label Text="⚠️ Crédito insuficiente para esta venta"
                                       FontSize="11" TextColor="#DC2626" FontAttributes="Bold"
                                       IsVisible="{Binding CreditInsufficient}"/>
                                <Label Text="{Binding CreditDaysText, StringFormat='Plazo: {0}'}"
                                       FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#FEF3C7"
                                Stroke="#F59E0B"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,10"
                                Margin="0,0,0,16"
                                IsVisible="{Binding HasStatusMessage}">
                            <Label Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   TextColor="#92400E"
                                   LineBreakMode="WordWrap"/>
                        </Border>

                        <Border BackgroundColor="#F8FAFC"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#E2E8F0"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Exoneración Hacienda"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="#334155"/>
                                        <Label Text="{Binding ExonerationScopeText}"
                                               FontSize="11"
                                               TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                    <Border BackgroundColor="#E2E8F0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="10,6"
                                            IsVisible="{Binding HasExoneration}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ClearExonerationCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Quitar"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="#475569"/>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <Border Grid.Column="0"
                                            BackgroundColor="White"
                                            Stroke="#CBD5E1"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,0"
                                            HeightRequest="42">
                                        <Entry Text="{Binding ExonerationAuthorization}"
                                               Placeholder="Ej. AL-00020402-24"
                                               ClearButtonVisibility="WhileEditing"
                                               FontSize="13"
                                               TextColor="#0F172A"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <Border Grid.Column="1"
                                            BackgroundColor="#0F766E"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="14,0"
                                             HeightRequest="42"
                                             InputTransparent="{Binding IsBusy}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ValidateExonerationCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Validar"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="White"
                                               VerticalOptions="Center"/>
                                    </Border>
                                </Grid>

                                <ActivityIndicator IsRunning="{Binding IsExonerationBusy}"
                                                   IsVisible="{Binding IsExonerationBusy}"
                                                   Color="#0F766E"
                                                   HorizontalOptions="Start"/>

                                <Border BackgroundColor="#ECFDF5"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="10,8"
                                        IsVisible="{Binding HasExoneration}">
                                    <Label Text="{Binding ExonerationSummaryText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#065F46"/>
                                </Border>

                                <Label Text="{Binding ExonerationStatusText}"
                                       FontSize="11"
                                       TextColor="#64748B"
                                       LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- PASO 1 — Forma de Pago Principal                       -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <Label Text="FORMA DE PAGO"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#94A3B8" Margin="0,0,0,6"
                               CharacterSpacing="1"/>

                        <Border BackgroundColor="White"
                                Stroke="#CBD5E1"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="8,2">
                            <Picker ItemsSource="{Binding Tenders}"
                                    ItemDisplayBinding="{Binding DisplayText}"
                                    SelectedItem="{Binding SelectedTender}"
                                    FontSize="14"
                                    TextColor="#1E293B"
                                    Title="Seleccione forma de pago"
                                    TitleColor="#94A3B8"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"/>
                        </Border>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- PASO 2 — Monto entregado y cambio                     -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <Border BackgroundColor="#F0FFF4"
                                Stroke="#BBF7D0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,12"
                                Margin="0,14,0,0">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding TenderedSectionTitle}"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="#15803D" CharacterSpacing="0.5"/>
                                <Label Text="{Binding TenderedSectionHint}"
                                       FontSize="10" TextColor="#6B7280"
                                       LineBreakMode="WordWrap"/>

                                <!-- Tip: solo visible con segundo medio activo -->
                                <Border BackgroundColor="#FFFBEB"
                                        Stroke="#FCD34D"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 7"
                                        Padding="10,7"
                                        IsVisible="{Binding HasSecondTender}">
                                    <Label FontSize="10" TextColor="#92400E" LineBreakMode="WordWrap">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="💡 " FontSize="11"/>
                                                <Span Text="Para dar cambio en efectivo, seleccione el método de efectivo como "
                                                      TextColor="#92400E"/>
                                                <Span Text="primer pago" FontAttributes="Bold" TextColor="#92400E"/>
                                                <Span Text=" y el otro como segundo pago."
                                                      TextColor="#92400E"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Border>

                                <Border BackgroundColor="White"
                                        Stroke="#86EFAC" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,0" HeightRequest="44">
                                    <Entry Text="{Binding TenderedText}"
                                           Placeholder="Ej. 5000"
                                           Keyboard="Numeric"
                                           FontSize="14" TextColor="#0F172A"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasChange}">
                                    <Label Text="Cambio" FontSize="14" FontAttributes="Bold"
                                           TextColor="#16A34A" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding ChangeText}"
                                           FontSize="20" FontAttributes="Bold"
                                           TextColor="#16A34A" HorizontalTextAlignment="End"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- PASO 3 — Pago dividido (opcional)                     -->
                        <!-- ═══════════════════════════════════════════════════════ -->
                        <Border x:Name="splitBorder"
                                BackgroundColor="#FAFBFF"
                                Stroke="#DBEAFE"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,10"
                                Margin="0,10,0,0"
                                InputTransparent="{Binding IsSubmitting}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding HasSecondTender}" Value="True">
                                    <Setter Property="BackgroundColor" Value="#EFF6FF"/>
                                    <Setter Property="Stroke" Value="#93C5FD"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="0">

                                <!-- Toggle -->
                                <Grid ColumnDefinitions="Auto, *">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleSecondTenderCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0"
                                           Text="💳"
                                           FontSize="16" VerticalOptions="Center" Margin="0,0,8,0"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                        <Label Text="{Binding SecondTenderToggleText}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="#1D4ED8"/>
                                        <Label Text="Usar dos medios de pago diferentes"
                                               FontSize="10" TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Contenido expandido -->
                                <VerticalStackLayout Spacing="10"
                                                     IsVisible="{Binding HasSecondTender}"
                                                     Margin="0,12,0,0">

                                    <!-- Monto del 2do pago -->
                                    <Label Text="{Binding SecondAmountLabelText}"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="#475569" CharacterSpacing="0.5"/>
                                    <Border BackgroundColor="White"
                                            Stroke="#93C5FD" StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,0" HeightRequest="44">
                                        <Entry Text="{Binding SecondAmountText}"
                                               Placeholder="Ej. 2000"
                                               Keyboard="Numeric"
                                               FontSize="14" TextColor="#0F172A"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Selección del segundo medio -->
                                    <Label Text="SEGUNDO MEDIO DE PAGO"
                                           FontSize="10" FontAttributes="Bold"
                                           TextColor="#475569" CharacterSpacing="0.5"
                                           Margin="0,4,0,0"/>
                                    <Border BackgroundColor="White"
                                            Stroke="#93C5FD"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="8,2">
                                        <Picker ItemsSource="{Binding Tenders}"
                                                ItemDisplayBinding="{Binding DisplayText}"
                                                SelectedItem="{Binding SecondTender}"
                                                FontSize="13"
                                                TextColor="#1E293B"
                                                Title="Seleccione segundo medio"
                                                TitleColor="#94A3B8"
                                                HorizontalOptions="Fill"
                                                VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Resumen del pago dividido -->
                                    <Border BackgroundColor="#EFF6FF"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,10">
                                        <VerticalStackLayout Spacing="4">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Text="{Binding SelectedTenderName}" FontSize="12"
                                                       TextColor="#1E40AF" VerticalOptions="Center"/>
                                                <Label Grid.Column="1" Text="{Binding FirstTenderAmountText}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="#1E40AF" HorizontalTextAlignment="End"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Text="{Binding SecondTenderSelectedText}" FontSize="12"
                                                       TextColor="#1E40AF" VerticalOptions="Center"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding SecondAmountFormattedText}"
                                                       FontSize="13" FontAttributes="Bold"
                                                       TextColor="#1E40AF" HorizontalTextAlignment="End"/>
                                            </Grid>
                                            <BoxView HeightRequest="1" BackgroundColor="#BFDBFE" Margin="0,2"/>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <Label Text="Total cubierto" FontSize="11"
                                                       TextColor="#64748B" VerticalOptions="Center"/>
                                                <Label Grid.Column="1" Text="{Binding SplitTotalText}"
                                                       FontSize="12" FontAttributes="Bold"
                                                       TextColor="#334155" HorizontalTextAlignment="End"/>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Footer buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*, *"
                      ColumnSpacing="10"
                      Padding="18,12">

                    <Border Grid.Column="0"
                            BackgroundColor="#F1F5F9"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14"
                            InputTransparent="{Binding IsSubmitting}"
                            Opacity="0.85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#475569" HorizontalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#22C55E"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14"
                            InputTransparent="{Binding IsSubmitting}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ConfirmCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                            <ActivityIndicator IsVisible="{Binding IsSubmitting}"
                                               IsRunning="{Binding IsSubmitting}"
                                               Color="White"
                                               WidthRequest="16"
                                               HeightRequest="16"
                                               VerticalOptions="Center"/>
                            <Label Text="&#x2705;" FontSize="15" VerticalOptions="Center"/>
                            <Label Text="{Binding ConfirmButtonText}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </Grid>

                <Grid Grid.RowSpan="3"
                      BackgroundColor="#66000000"
                      IsVisible="{Binding IsSubmitting}">
                    <Border BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="18,16"
                            MaximumWidthRequest="260"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <VerticalStackLayout Spacing="10">
                            <ActivityIndicator IsRunning="True"
                                               Color="#22C55E"
                                               HorizontalOptions="Center"/>
                            <Label Text="Procesando venta"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Se está enviando la transacción al servidor."
                                   FontSize="12"
                                   TextColor="#64748B"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
