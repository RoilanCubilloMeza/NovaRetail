<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CheckoutPopup"
             x:Name="Root">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                MaximumWidthRequest="480"
                Margin="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Shadow="{x:Null}">

            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="0">

                <!-- Title bar -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14,14,0,0"
                        Padding="18,12">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="&#x2705;" FontSize="16"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Confirmar Cobro"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                            <Label Text="Revise el total y la forma de pago antes de confirmar."
                                   FontSize="11"
                                   TextColor="#CBD5E1"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollView Grid.Row="1"
                            InputTransparent="{Binding IsSubmitting}">
                    <VerticalStackLayout Spacing="0" Padding="18,16,18,8">

                        <!-- Resumen de totales -->
                        <Border BackgroundColor="#F8FAFC"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#E2E8F0"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Subtotal"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding SubtotalText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasDiscount}">
                                    <Label Grid.Column="0" Text="Descuentos"
                                           FontSize="13" TextColor="#EF4444" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding DiscountText}"
                                           FontSize="13" TextColor="#EF4444" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding TaxSystemText}"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,4"/>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="TOTAL"
                                           FontSize="17" FontAttributes="Bold"
                                           TextColor="#1E293B" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                        <Label Text="{Binding TotalText}"
                                               FontSize="22" FontAttributes="Bold"
                                               TextColor="#1E293B" HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding TotalColonesText}"
                                               FontSize="12" TextColor="#64748B"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        <!-- IVA + Cotización pills -->
                        <Grid ColumnDefinitions="*, 8, *" Margin="0,0,0,16">
                            <Border Grid.Column="0" BackgroundColor="#F0FDF4"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="IVA" FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxSystemText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#065F46"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#EFF6FF"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="Cotiz." FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding QuoteDaysText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="#EEF2FF"
                                Stroke="#C7D2FE"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,10"
                                Margin="0,0,0,16">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Cobro"
                                       FontSize="11"
                                       TextColor="#6366F1"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding SelectedTenderText}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#1E1B4B"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border BackgroundColor="#FEF3C7"
                                Stroke="#F59E0B"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="12,10"
                                Margin="0,0,0,16"
                                IsVisible="{Binding HasStatusMessage}">
                            <Label Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   TextColor="#92400E"
                                   LineBreakMode="WordWrap"/>
                        </Border>

                        <Border BackgroundColor="#F8FAFC"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#E2E8F0"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Exoneración Hacienda"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="#334155"/>
                                        <Label Text="{Binding ExonerationScopeText}"
                                               FontSize="11"
                                               TextColor="#64748B"/>
                                    </VerticalStackLayout>
                                    <Border BackgroundColor="#E2E8F0"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="10,6"
                                            IsVisible="{Binding HasExoneration}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ClearExonerationCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Quitar"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="#475569"/>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                                    <Border Grid.Column="0"
                                            BackgroundColor="White"
                                            Stroke="#CBD5E1"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="12,0"
                                            HeightRequest="42">
                                        <Entry Text="{Binding ExonerationAuthorization}"
                                               Placeholder="Ej. AL-00020402-24"
                                               ClearButtonVisibility="WhileEditing"
                                               FontSize="13"
                                               TextColor="#0F172A"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <Border Grid.Column="1"
                                            BackgroundColor="#0F766E"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            Padding="14,0"
                                             HeightRequest="42"
                                             InputTransparent="{Binding IsBusy}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ValidateExonerationCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Validar"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="White"
                                               VerticalOptions="Center"/>
                                    </Border>
                                </Grid>

                                <ActivityIndicator IsRunning="{Binding IsExonerationBusy}"
                                                   IsVisible="{Binding IsExonerationBusy}"
                                                   Color="#0F766E"
                                                   HorizontalOptions="Start"/>

                                <Border BackgroundColor="#ECFDF5"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="10,8"
                                        IsVisible="{Binding HasExoneration}">
                                    <Label Text="{Binding ExonerationSummaryText}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#065F46"/>
                                </Border>

                                <Label Text="{Binding ExonerationStatusText}"
                                       FontSize="11"
                                       TextColor="#64748B"
                                       LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Formas de pago -->
                        <Label Text="Forma de Pago"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#475569" Margin="0,0,0,8"/>

                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding Tenders}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 9"
                                            StrokeThickness="2"
                                            Stroke="#E2E8F0"
                                            BackgroundColor="White"
                                             Padding="12,10"
                                             InputTransparent="{Binding Source={x:Reference Root}, Path=BindingContext.IsSubmitting}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectTenderCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#F1F5F9"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    WidthRequest="32" HeightRequest="32"
                                                    Padding="0">
                                                <Label Text="{Binding CurrencySymbol}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       TextColor="#475569"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Description}"
                                                   FontSize="13" TextColor="#1E293B"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- ── Monto Entregado y Cambio ──────────────────────────── -->
                        <Border BackgroundColor="#F0FFF4"
                                Stroke="#BBF7D0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,12"
                                Margin="0,14,0,0">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Monto Entregado  (dejar vacío = cobro exacto)"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="#15803D"/>
                                <Border BackgroundColor="White"
                                        Stroke="#86EFAC" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,0" HeightRequest="42">
                                    <Entry Text="{Binding TenderedText}"
                                           Placeholder="Ej. 5000"
                                           Keyboard="Numeric"
                                           FontSize="13" TextColor="#0F172A"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasChange}">
                                    <Label Text="Cambio" FontSize="14" FontAttributes="Bold"
                                           TextColor="#16A34A" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding ChangeText}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#16A34A" HorizontalTextAlignment="End"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- ── Toggle segundo medio de pago ──────────────────────── -->
                        <Border BackgroundColor="#EFF6FF"
                                Stroke="#BFDBFE" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,10"
                                Margin="0,10,0,0"
                                InputTransparent="{Binding IsSubmitting}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleSecondTenderCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="{Binding SecondTenderToggleText}"
                                   FontSize="12" FontAttributes="Bold" TextColor="#1D4ED8"/>
                        </Border>

                        <!-- ── Panel segundo medio de pago ───────────────────────── -->
                        <Border BackgroundColor="#F8FAFC"
                                Stroke="#CBD5E1" StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="14,12"
                                Margin="0,8,0,0"
                                IsVisible="{Binding HasSecondTender}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Segundo Medio de Pago"
                                       FontSize="12" FontAttributes="Bold" TextColor="#475569"/>

                                <VerticalStackLayout Spacing="5"
                                                     BindableLayout.ItemsSource="{Binding Tenders}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border StrokeShape="RoundRectangle 8"
                                                    StrokeThickness="1" Stroke="#E2E8F0"
                                                    BackgroundColor="White" Padding="10,8"
                                                    InputTransparent="{Binding Source={x:Reference Root}, Path=BindingContext.IsSubmitting}">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectSecondTenderCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="{Binding Description}"
                                                       FontSize="12" TextColor="#1E293B"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <Label Text="{Binding SecondTenderSelectedText}"
                                       FontSize="11" TextColor="#1D4ED8" FontAttributes="Bold"/>

                                <Label Text="Monto (₡)" FontSize="11" TextColor="#64748B"/>
                                <Border BackgroundColor="White"
                                        Stroke="#CBD5E1" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12,0" HeightRequest="42">
                                    <Entry Text="{Binding SecondAmountText}"
                                           Placeholder="Ej. 2000"
                                           Keyboard="Numeric"
                                           FontSize="13" TextColor="#0F172A"
                                           VerticalOptions="Center"/>
                                </Border>

                                <Label Text="{Binding SplitSummaryText}"
                                       FontSize="11" TextColor="#64748B"
                                       IsVisible="{Binding HasSecondTender}"/>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Footer buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*, *"
                      ColumnSpacing="10"
                      Padding="18,12">

                    <Border Grid.Column="0"
                            BackgroundColor="#F1F5F9"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14"
                            InputTransparent="{Binding IsSubmitting}"
                            Opacity="0.85">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#475569" HorizontalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#22C55E"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14"
                            InputTransparent="{Binding IsSubmitting}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ConfirmCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                            <ActivityIndicator IsVisible="{Binding IsSubmitting}"
                                               IsRunning="{Binding IsSubmitting}"
                                               Color="White"
                                               WidthRequest="16"
                                               HeightRequest="16"
                                               VerticalOptions="Center"/>
                            <Label Text="&#x2705;" FontSize="15" VerticalOptions="Center"/>
                            <Label Text="{Binding ConfirmButtonText}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </Grid>

                <Grid Grid.RowSpan="3"
                      BackgroundColor="#66000000"
                      IsVisible="{Binding IsSubmitting}">
                    <Border BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="18,16"
                            MaximumWidthRequest="260"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <VerticalStackLayout Spacing="10">
                            <ActivityIndicator IsRunning="True"
                                               Color="#22C55E"
                                               HorizontalOptions="Center"/>
                            <Label Text="Procesando venta"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Se está enviando la transacción al servidor."
                                   FontSize="12"
                                   TextColor="#64748B"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
