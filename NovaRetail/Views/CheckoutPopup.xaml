<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CheckoutPopup">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                MaximumWidthRequest="480"
                Margin="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Shadow="{x:Null}">

            <Grid RowDefinitions="Auto, *, Auto" RowSpacing="0">

                <!-- Title bar -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14,14,0,0"
                        Padding="18,12">
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="&#x2705;" FontSize="16"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1" Text="Confirmar Cobro"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Spacing="0" Padding="18,16,18,8">

                        <!-- Resumen de totales -->
                        <Border BackgroundColor="#F8FAFC"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="1"
                                Stroke="#E2E8F0"
                                Padding="16,12"
                                Margin="0,0,0,14">
                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="Subtotal"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding SubtotalText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding HasDiscount}">
                                    <Label Grid.Column="0" Text="Descuentos"
                                           FontSize="13" TextColor="#EF4444" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding DiscountText}"
                                           FontSize="13" TextColor="#EF4444" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="{Binding TaxSystemText}"
                                           FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxText}"
                                           FontSize="13" TextColor="#334155" FontAttributes="Bold"
                                           HorizontalTextAlignment="End"/>
                                </Grid>

                                <BoxView HeightRequest="1" BackgroundColor="#E2E8F0" Margin="0,4"/>

                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0" Text="TOTAL"
                                           FontSize="17" FontAttributes="Bold"
                                           TextColor="#1E293B" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                                        <Label Text="{Binding TotalText}"
                                               FontSize="22" FontAttributes="Bold"
                                               TextColor="#1E293B" HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding TotalColonesText}"
                                               FontSize="12" TextColor="#64748B"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        <!-- IVA + Cotización pills -->
                        <Grid ColumnDefinitions="*, 8, *" Margin="0,0,0,16">
                            <Border Grid.Column="0" BackgroundColor="#F0FDF4"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="IVA" FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding TaxSystemText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#065F46"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#EFF6FF"
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,7">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="4">
                                    <Label Grid.Column="0" Text="Cotiz." FontSize="11"
                                           TextColor="#6B7280" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding QuoteDaysText}"
                                           FontSize="11" FontAttributes="Bold" TextColor="#1D4ED8"
                                           HorizontalTextAlignment="End" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Formas de pago -->
                        <Label Text="Forma de Pago"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#475569" Margin="0,0,0,8"/>

                        <VerticalStackLayout Spacing="6"
                                             BindableLayout.ItemsSource="{Binding Tenders}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 9"
                                            StrokeThickness="2"
                                            Stroke="#E2E8F0"
                                            BackgroundColor="White"
                                            Padding="12,10">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectTenderCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#F1F5F9"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    WidthRequest="32" HeightRequest="32"
                                                    Padding="0">
                                                <Label Text="{Binding CurrencySymbol}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       TextColor="#475569"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Description}"
                                                   FontSize="13" TextColor="#1E293B"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Footer buttons -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*, *"
                      ColumnSpacing="10"
                      Padding="18,12">

                    <Border Grid.Column="0"
                            BackgroundColor="#F1F5F9"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#475569" HorizontalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#22C55E"
                            StrokeShape="RoundRectangle 9"
                            StrokeThickness="0"
                            Padding="0,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ConfirmCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                            <Label Text="&#x2705;" FontSize="15" VerticalOptions="Center"/>
                            <Label Text="Confirmar"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="White" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentView>
