<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:NovaRetail.Controls"
             x:Class="NovaRetail.Views.ClienteIdPanel">

    <controls:SectionCard Title="Identificación">
        <VerticalStackLayout Spacing="0">

            <!-- ID Cliente -->
            <Label Text="Identificación del cliente" Style="{DynamicResource FieldLabel}"/>
            <Border Style="{DynamicResource InputBox}">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Grid.Column="0"
                           Placeholder="Ingrese cédula o identificación"
                           Text="{Binding ClientId}"
                            Keyboard="{Binding ClientIdKeyboard}"
                           ReturnType="Next"
                           IsEnabled="{Binding IsNotSyncing}"
                           BackgroundColor="Transparent"
                           FontSize="14"
                           ReturnCommand="{Binding SyncCommand}"/>
                    <Label Grid.Column="1"
                           Style="{DynamicResource IconLabel}"
                           Text="&#x2398;"
                           FontSize="18"
                           TextColor="{DynamicResource Gray300}"
                           Margin="4,0,2,0"/>
                </Grid>
            </Border>

            <!-- Sincronizar -->
            <Button Text="{Binding SyncText}"
                    BackgroundColor="{Binding SyncButtonBackground}"
                    TextColor="White"
                    Command="{Binding SyncCommand}"
                    IsEnabled="{Binding IsNotSyncing}"
                    HorizontalOptions="Fill"
                    FontAttributes="Bold"
                    FontSize="14"
                    CornerRadius="8"
                    HeightRequest="46"
                    Margin="0,10,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsSyncing}"
                               IsVisible="{Binding IsSyncing}"
                               Color="{DynamicResource AccentGreen}"
                               HorizontalOptions="Center"
                               HeightRequest="20"
                               Margin="0,4,0,0"/>

            <!-- TipoID -->
            <controls:FormPicker ItemsSource="{Binding IdentificationTypes}"
                                 SelectedItem="{Binding IdType, Mode=TwoWay}"
                                 Title="Tipo de identificación"
                                 FontSize="13"
                                 Margin="0,14,0,0"/>

                 <Label Text="Primero se busca el cliente en su base. Si no existe, se intentan traer datos automáticos para completar el formulario."
                     Style="{DynamicResource HelpText}"
                     Margin="0,12,0,0"/>

                 <Border BackgroundColor="{Binding ClientStatusBackgroundColor}"
                      Stroke="{Binding ClientStatusBorderColor}"
                      StrokeShape="RoundRectangle 10"
                      StrokeThickness="1"
                      Padding="12,10"
                      Margin="0,12,0,0">
                  <VerticalStackLayout Spacing="3">
                      <Label Text="{Binding ClientStatusTitle}"
                          FontSize="13"
                          FontAttributes="Bold"
                          TextColor="{Binding ClientStatusTitleColor}"/>
                      <Label Text="{Binding ClientStatusHint}"
                          Style="{DynamicResource HelpText}"
                          TextColor="{DynamicResource Gray600}"/>
                  </VerticalStackLayout>
                 </Border>

        </VerticalStackLayout>
    </controls:SectionCard>

</ContentView>
