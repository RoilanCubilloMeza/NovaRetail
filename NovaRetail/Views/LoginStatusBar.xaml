<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.LoginStatusBar">

    <Border StrokeThickness="0"
            Padding="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#0F4C81" Offset="0.0"/>
                <GradientStop Color="#0EA5E9" Offset="0.45"/>
                <GradientStop Color="#0369A1" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid ColumnDefinitions="Auto,*,Auto"
              Padding="16,0"
              HeightRequest="48">
            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="8"
                                   VerticalOptions="Center">
                <Label Text="&#x2605;"
                       Style="{StaticResource LoginTopBarAccent}"/>
                <Label Text="Nova Retail"
                       Style="{StaticResource LoginTopBarBrand}"/>
                <BoxView WidthRequest="1"
                         HeightRequest="20"
                         Color="#FFFFFF50"
                         VerticalOptions="Center"
                         Margin="4,0"/>
                <Label Text="{Binding AppVersionText}"
                       Style="{StaticResource LoginTopBarMuted}"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="1"
                                   Spacing="8"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                <Label Text="&#x25CF;"
                       FontSize="9"
                       TextColor="#4ADE80"
                       VerticalOptions="Center"/>
                <Label Text="{Binding DatabaseStatusText}"
                       Style="{StaticResource LoginTopBarHighlight}"/>
                <BoxView WidthRequest="1"
                         HeightRequest="20"
                         Color="#FFFFFF50"
                         VerticalOptions="Center"
                         Margin="4,0"/>
                <Label Text="{Binding HostText}"
                       Style="{StaticResource LoginTopBarText}"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="8"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center">
                <BoxView WidthRequest="1"
                         HeightRequest="20"
                         Color="#FFFFFF50"
                         VerticalOptions="Center"
                         Margin="4,0"/>
                <Label Text="&#x1F4C5;"
                       Style="{StaticResource LoginTopBarMuted}"/>
                <Label Text="{Binding DateText}"
                       Style="{StaticResource LoginTopBarText}"/>
                <BoxView WidthRequest="1"
                         HeightRequest="20"
                         Color="#FFFFFF50"
                         VerticalOptions="Center"
                         Margin="4,0"/>
                <Label Text="&#x23F0;"
                       Style="{StaticResource LoginTopBarMuted}"/>
                <Label Text="{Binding TimeText}"
                       Style="{StaticResource LoginTopBarTime}"/>
            </HorizontalStackLayout>
        </Grid>
    </Border>
</ContentView>