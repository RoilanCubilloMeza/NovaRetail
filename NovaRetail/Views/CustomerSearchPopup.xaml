<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NovaRetail.Views.CustomerSearchPopup">

    <Grid>
        <BoxView Color="#000000" Opacity="0.55"/>

        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                MaximumWidthRequest="960"
                MaximumHeightRequest="640"
                Margin="20"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Shadow="{x:Null}">

            <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" RowSpacing="0">

                <!-- Row 0: Title bar -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14,14,0,0"
                        Padding="18,12">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Label Grid.Column="0" Text="&#x1F465;" FontSize="16"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Label Grid.Column="1"
                               Text="Búsqueda de Cliente"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="{Binding CountText}"
                               FontSize="11" TextColor="#94A3B8"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Row 1: Search hint -->
                <Label Grid.Row="1"
                       Text="número de cuenta, nombre, apellido, teléfono, correo electrónico, dirección, ciudad, estado, código postal"
                       FontSize="10"
                       TextColor="#9CA3AF"
                       Padding="18,6,18,0"
                       LineBreakMode="WordWrap"/>

                <!-- Row 2: Search bar -->
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto" ColumnSpacing="8"
                      Padding="18,8,18,6">
                    <Border Grid.Column="0"
                            BackgroundColor="#F9FAFB"
                            Stroke="#CBD5E1"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            Padding="12,0"
                            HeightRequest="42">
                        <Entry Text="{Binding SearchText}"
                               Placeholder="Buscar cliente..."
                               ReturnCommand="{Binding SearchCommand}"
                               ClearButtonVisibility="WhileEditing"
                               FontSize="13"
                               TextColor="#0F172A"
                               VerticalOptions="Center"/>
                    </Border>
                    <Button Grid.Column="1"
                            Text="Buscar"
                            Command="{Binding SearchCommand}"
                            FontSize="12"
                            BackgroundColor="#3B82F6"
                            TextColor="White"
                            HeightRequest="40"
                            CornerRadius="8"
                            Padding="16,0"/>
                    <Button Grid.Column="2"
                            Text="&#x21BB;"
                            Command="{Binding ClearSearchCommand}"
                            FontSize="16"
                            BackgroundColor="#F3F4F6"
                            TextColor="#374151"
                            HeightRequest="40"
                            WidthRequest="40"
                            CornerRadius="8"
                            Padding="0"/>
                </Grid>

                <!-- Row 3: Results grid -->
                <Grid Grid.Row="3" RowDefinitions="Auto, *" Padding="18,0,18,0">

                    <!-- Header row -->
                    <Grid Grid.Row="0"
                          ColumnDefinitions="90, 2*, 1.5*, 1.5*, 2*, 1.2*, 100"
                          ColumnSpacing="6"
                          Padding="10,6"
                          BackgroundColor="#F1F5F9">
                        <Label Grid.Column="0" Text="Cuenta" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="1" Text="Apellido" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="2" Text="Nombre" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="3" Text="Dirección" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="4" Text="Ciudad" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="5" Text="Estado" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                        <Label Grid.Column="6" Text="Teléfono" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                    </Grid>

                    <!-- Customer list -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding Customers}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="{Binding StatusMessage}"
                                   FontSize="13"
                                   TextColor="#9CA3AF"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   Margin="0,30"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 4"
                                        Stroke="#E5E7EB"
                                        BackgroundColor="White"
                                        Padding="10,8"
                                        Margin="0,1">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentView}}, Path=BindingContext.SelectCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="90, 2*, 1.5*, 1.5*, 2*, 1.2*, 100"
                                          ColumnSpacing="6">
                                        <Label Grid.Column="0"
                                               Text="{Binding AccountNumber}"
                                               FontSize="12" TextColor="#111827"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding LastName}"
                                               FontSize="12" TextColor="#111827"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding FirstName}"
                                               FontSize="12" TextColor="#111827"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="3"
                                               Text="{Binding Address}"
                                               FontSize="11" TextColor="#6B7280"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="4"
                                               Text="{Binding City}"
                                               FontSize="11" TextColor="#6B7280"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="5"
                                               Text="{Binding State}"
                                               FontSize="11" TextColor="#6B7280"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="6"
                                               Text="{Binding Phone}"
                                               FontSize="11" TextColor="#6B7280"
                                               LineBreakMode="TailTruncation"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>

                <!-- Row 4: Activity indicator + buttons -->
                <Grid Grid.Row="4" Padding="18,8,18,14">
                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                        <ActivityIndicator Grid.Column="0"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           Color="#3B82F6"
                                           HeightRequest="24"
                                           WidthRequest="24"
                                           VerticalOptions="Center"/>
                        <Label Grid.Column="1"/>
                        <Button Grid.Column="2"
                                Text="Cancelar"
                                Command="{Binding CloseCommand}"
                                FontSize="13"
                                BackgroundColor="#F3F4F6"
                                TextColor="#374151"
                                HeightRequest="40"
                                CornerRadius="8"
                                Padding="20,0"/>
                    </Grid>
                </Grid>

            </Grid>
        </Border>
    </Grid>

</ContentView>
