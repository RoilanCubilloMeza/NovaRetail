<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:NovaRetail.Views"
             x:Class="NovaRetail.Pages.ClientePage"
             Title="Cliente"
             BackgroundColor="{DynamicResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid ColumnDefinitions="1*, 12*, 1*" RowDefinitions="Auto" Padding="0,16,0,24">
            <Grid Grid.Column="1"
                  ColumnDefinitions="1*, 2*"
                  RowDefinitions="Auto"
                  ColumnSpacing="14">

                <views:ClienteIdPanel   Grid.Column="0"/>
                <views:ClienteDataPanel Grid.Column="1"/>

            </Grid>
        </Grid>
    </ScrollView>

</ContentPage>
