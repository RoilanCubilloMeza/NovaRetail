<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NovaRetail.ViewModels"
             xmlns:m="clr-namespace:NovaRetail.Models"
             xmlns:views="clr-namespace:NovaRetail.Views"
             x:Class="NovaRetail.Pages.InvoiceHistoryPage"
             Title="Historial de Facturas"
             BackgroundColor="#F1F5F9">

    <Grid>
        <!-- LISTA -->
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0"
              IsVisible="{Binding HasSelectedEntry, Converter={StaticResource InvertBoolConverter}}">

            <!-- Header -->
            <Border Grid.Row="0"
                    BackgroundColor="#0F172A"
                    StrokeThickness="0"
                    Padding="20,16,20,14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="#1E3A5F"
                            Stroke="#3B82F6"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 12"
                            WidthRequest="40" HeightRequest="40"
                            VerticalOptions="Center">
                        <Label Text="&#x1F9FE;" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                        <Label Text="Historial de Facturas"
                               FontSize="17" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="Facturas locales y del servidor"
                               FontSize="11" TextColor="#93C5FD"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2"
                            Text="&#x1F5D1; Limpiar"
                            Command="{Binding ClearAllCommand}"
                            IsEnabled="{Binding HasLocalEntries}"
                            BackgroundColor="#7F1D1D"
                            TextColor="White"
                            FontSize="11" FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="36"
                            Padding="12,0"/>
                </Grid>
            </Border>

            <!-- Buscador -->
            <Border Grid.Row="1"
                    BackgroundColor="White"
                    Stroke="#E2E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 0"
                    Padding="16,10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="&#x1F50D;" FontSize="16" VerticalOptions="Center"/>
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           Placeholder="Buscar por cliente, cedula, No. o tipo..."
                           PlaceholderColor="#94A3B8"
                           FontSize="13"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Indicador de carga -->
            <VerticalStackLayout Grid.Row="2"
                                 IsVisible="{Binding IsLoading}"
                                 Spacing="10"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#2563EB"
                                   HeightRequest="40" WidthRequest="40"
                                   HorizontalOptions="Center"/>
                <Label Text="{Binding LoadingMessageText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#334155"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Espere un momento..."
                       FontSize="12"
                       TextColor="#94A3B8"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Estado vacï¿½o -->
            <VerticalStackLayout Grid.Row="2"
                                 IsVisible="{Binding IsCompletelyEmpty}"
                                 Spacing="10"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="&#x1F4C4;" FontSize="48" HorizontalTextAlignment="Center"/>
                <Label Text="No hay facturas registradas"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#64748B" HorizontalTextAlignment="Center"/>
                <Label Text="Las ventas completadas apareceran aqui"
                       FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Estado vacï¿½o: bï¿½squeda sin resultados -->
            <VerticalStackLayout Grid.Row="2"
                                 IsVisible="{Binding IsSearchEmpty}"
                                 Spacing="10"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="&#x1F50D;" FontSize="48" HorizontalTextAlignment="Center"/>
                <Label Text="Sin resultados"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#64748B" HorizontalTextAlignment="Center"/>
                <Label Text="No se encontraron facturas con ese criterio"
                       FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Lista de facturas -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding Entries}"
                            IsVisible="{Binding HasEntries}"
                            SelectionMode="None"
                            ItemSizingStrategy="MeasureFirstItem"
                            Margin="0,4,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:InvoiceHistoryEntry">
                        <Border BackgroundColor="White"
                                Stroke="#E2E8F0"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14"
                                Margin="12,4,12,4"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InvoiceHistoryViewModel}}, Path=SelectEntryCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="14,12">
                                <!-- Icono tipo doc -->
                                <Border Grid.Column="0"
                                        BackgroundColor="#EFF6FF"
                                        Stroke="#BFDBFE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        WidthRequest="44" HeightRequest="44"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding DocumentIcon}" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <!-- Info central -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding ClientName}"
                                           FontSize="14" FontAttributes="Bold" TextColor="#0F172A"
                                           LineBreakMode="TailTruncation"/>
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding DocumentTypeName}"
                                               FontSize="11" TextColor="#64748B"/>
                                        <Label Text="&#x2022;" FontSize="11" TextColor="#CBD5E1"/>
                                        <Label Text="{Binding TransactionText}"
                                               FontSize="11" TextColor="#2563EB" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding ClientMetaText}"
                                           FontSize="10" TextColor="#94A3B8"/>
                                </VerticalStackLayout>

                                <!-- Total + botones -->
                                <VerticalStackLayout Grid.Column="2" Spacing="6"
                                                     HorizontalOptions="End" VerticalOptions="Center">
                                    <Label Text="{Binding TotalColonesText}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#0F172A" HorizontalTextAlignment="End"/>
                                    <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                        <Button Text="&#x1F5A8;"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InvoiceHistoryViewModel}}, Path=ReprintCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#EFF6FF"
                                                TextColor="#2563EB"
                                                FontSize="12"
                                                CornerRadius="8"
                                                HeightRequest="30"
                                                WidthRequest="38"
                                                Padding="0"/>
                                        <Button Text="&#x1F5D1;"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InvoiceHistoryViewModel}}, Path=DeleteCommand}"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding CanDelete}"
                                                BackgroundColor="#FEF2F2"
                                                TextColor="#DC2626"
                                                FontSize="12"
                                                CornerRadius="8"
                                                HeightRequest="30"
                                                WidthRequest="38"
                                                Padding="0"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="16" Color="Transparent"/>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>

        <!-- DETALLE -->
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0"
              IsVisible="{Binding HasSelectedEntry}">

            <!-- Header detalle -->
            <Border Grid.Row="0"
                    BackgroundColor="#0F172A"
                    StrokeThickness="0"
                    Padding="20,16,20,14">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="&#x2190; Volver"
                            Command="{Binding CloseDetailCommand}"
                            BackgroundColor="#1E3A5F"
                            TextColor="#93C5FD"
                            FontSize="12"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="36"
                            Padding="12,0"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                        <Label Text="{Binding SelectedEntry.DocumentTypeName}"
                               FontSize="16" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding SelectedEntry.DateText}"
                               FontSize="11" TextColor="#93C5FD"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="2"
                            BackgroundColor="#1D4ED8"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,6"
                            VerticalOptions="Center">
                        <Label Text="{Binding SelectedEntry.TransactionText}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Cuerpo del detalle -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,14,16,16" Spacing="12">

                    <!-- Tarjeta cliente / cajero -->
                    <Border BackgroundColor="White"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="16,12">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="3">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding SelectedEntry.ClientName}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#0F172A"/>
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding SelectedEntry.ClientId}"
                                   FontSize="11" TextColor="#64748B"/>
                            <VerticalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                 Spacing="3" HorizontalOptions="End" VerticalOptions="Center">
                                <Label Text="{Binding SelectedEntry.CashierName}"
                                       FontSize="11" TextColor="#334155"
                                       HorizontalTextAlignment="End"/>
                                <Border BackgroundColor="#EFF6FF"
                                        Stroke="#BFDBFE"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 6"
                                        Padding="8,3" HorizontalOptions="End">
                                    <Label Text="{Binding SelectedEntry.RegisterNumber, StringFormat='Reg.POS #: {0}'}"
                                           FontSize="9" FontAttributes="Bold" TextColor="#2563EB"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Clave fiscal (si aplica) -->
                    <Border BackgroundColor="#F0FDF4"
                            Stroke="#86EFAC"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="14,10"
                            IsVisible="{Binding SelectedEntry.HasFiscalData}">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="Datos fiscales"
                                   FontSize="11" FontAttributes="Bold" TextColor="#16A34A"/>
                            <Label Text="{Binding SelectedEntry.Clave50}"
                                   FontSize="10" TextColor="#166534"
                                   LineBreakMode="CharacterWrap"/>
                            <Label Text="{Binding SelectedEntry.Consecutivo}"
                                   FontSize="10" TextColor="#166534"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Encabezado lï¿½neas -->
                    <Grid ColumnDefinitions="*,54,94,100" ColumnSpacing="4" Padding="4,0">
                        <Label Grid.Column="0" Text="ARTICULO"
                               FontSize="10" FontAttributes="Bold" TextColor="#94A3B8" CharacterSpacing="0.5"/>
                        <Label Grid.Column="1" Text="CANT."
                               FontSize="10" FontAttributes="Bold" TextColor="#94A3B8"
                               HorizontalTextAlignment="End" CharacterSpacing="0.5"/>
                        <Label Grid.Column="2" Text="PRECIO"
                               FontSize="10" FontAttributes="Bold" TextColor="#94A3B8"
                               HorizontalTextAlignment="End" CharacterSpacing="0.5"/>
                        <Label Grid.Column="3" Text="TOTAL"
                               FontSize="10" FontAttributes="Bold" TextColor="#94A3B8"
                               HorizontalTextAlignment="End" CharacterSpacing="0.5"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#E2E8F0"/>

                    <!-- Lï¿½neas de artï¿½culos -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedEntry.Lines}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="m:InvoiceHistoryLine">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="*,54,94,100" ColumnSpacing="4" Padding="4,10,4,10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="#0F172A" LineBreakMode="WordWrap"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Code}"
                                                       FontSize="10" TextColor="#94A3B8"/>
                                                <Border BackgroundColor="#F0FDF4"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 4"
                                                        Padding="5,1"
                                                        IsVisible="{Binding HasTax}">
                                                    <Label Text="{Binding TaxPercentageText}"
                                                           FontSize="9" FontAttributes="Bold" TextColor="#16A34A"/>
                                                </Border>
                                            </HorizontalStackLayout>
                                            <Border BackgroundColor="#FEF2F2"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="5,2"
                                                    IsVisible="{Binding HasDiscount}">
                                                <Label Text="{Binding DiscountText}"
                                                       FontSize="9" TextColor="#DC2626"/>
                                            </Border>
                                            <Border BackgroundColor="#F0FDFA"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 4"
                                                    Padding="5,2"
                                                    IsVisible="{Binding HasExoneration}">
                                                <Label Text="{Binding ExonerationText}"
                                                       FontSize="9" TextColor="#0D9488"/>
                                            </Border>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding QuantityText}"
                                               FontSize="12" TextColor="#334155"
                                               HorizontalTextAlignment="End" VerticalOptions="Start"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding UnitPriceText}"
                                               FontSize="12" TextColor="#334155"
                                               HorizontalTextAlignment="End" VerticalOptions="Start"/>
                                        <Label Grid.Column="3"
                                               Text="{Binding LineTotalText}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="#0F172A"
                                               HorizontalTextAlignment="End" VerticalOptions="Start"/>
                                    </Grid>
                                    <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="4,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Totales -->
                    <Border BackgroundColor="#F8FAFC"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="16,12">
                        <VerticalStackLayout Spacing="7">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Sub Total"
                                       FontSize="13" TextColor="#64748B"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.SubtotalColonesText}"
                                       FontSize="13" TextColor="#334155" HorizontalTextAlignment="End"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding SelectedEntry.HasDiscount}">
                                <Label Grid.Column="0" Text="Descuentos"
                                       FontSize="13" FontAttributes="Bold" TextColor="#EF4444"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.DiscountColonesNegativeText}"
                                       FontSize="13" FontAttributes="Bold" TextColor="#EF4444"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding SelectedEntry.HasExoneration}">
                                <Label Grid.Column="0" Text="Exoneracion"
                                       FontSize="13" FontAttributes="Bold" TextColor="#0D9488"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.ExonerationColonesNegativeText}"
                                       FontSize="13" FontAttributes="Bold" TextColor="#0D9488"
                                       HorizontalTextAlignment="End"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Imp. Ventas"
                                       FontSize="13" TextColor="#64748B"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.TaxColonesText}"
                                       FontSize="13" TextColor="#334155" HorizontalTextAlignment="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Total grande -->
                    <Border BackgroundColor="#0F172A"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            Padding="18,14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="TOTAL"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#94A3B8" CharacterSpacing="2"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding SelectedEntry.TotalColonesText}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="White" HorizontalTextAlignment="End"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Forma de pago -->
                    <Border BackgroundColor="#F8FAFC"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="16,12">
                        <VerticalStackLayout Spacing="7">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedEntry.TenderDeliveredText}"
                                       FontSize="13" TextColor="#334155"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.TenderTotalColonesText}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#0F172A" HorizontalTextAlignment="End"/>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{Binding SelectedEntry.HasSecondTender}">
                                <Label Grid.Column="0"
                                       Text="{Binding SelectedEntry.SecondTenderText}"
                                       FontSize="13" TextColor="#334155"/>
                                <Label Grid.Column="1"
                                       Text="{Binding SelectedEntry.SecondTenderAmountText}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#0F172A" HorizontalTextAlignment="End"/>
                            </Grid>
                            <Border BackgroundColor="#DCFCE7"
                                    Stroke="#86EFAC"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="14,10"
                                    IsVisible="{Binding SelectedEntry.HasChange}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="CAMBIO"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="#16A34A" VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding SelectedEntry.ChangeColonesText}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#16A34A" HorizontalTextAlignment="End"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Footer detalle con botï¿½n reimprimir -->
            <Border Grid.Row="2"
                    BackgroundColor="#F8FAFC"
                    Stroke="#E2E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 0"
                    Padding="16,12">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="&#x1F5A8; Reimprimir"
                            Command="{Binding ReprintCommand}"
                            CommandParameter="{Binding SelectedEntry}"
                            BackgroundColor="#2563EB" TextColor="White"
                            FontAttributes="Bold" FontSize="14"
                            CornerRadius="12" HeightRequest="48"/>
                    <Button Grid.Column="1"
                            Text="Cerrar"
                            Command="{Binding CloseDetailCommand}"
                            BackgroundColor="#0F172A" TextColor="White"
                            FontAttributes="Bold" FontSize="14"
                            CornerRadius="12" HeightRequest="48"/>
                </Grid>
            </Border>
        </Grid>

        <!-- OVERLAY REIMPRIMIR -->
        <Grid IsVisible="{Binding IsReprintVisible}">
            <views:ReceiptPopup BindingContext="{Binding ReprintVm}"/>
        </Grid>
    </Grid>
</ContentPage>


